@model Cavex.Principal.Models.ServicioACliente

@{
    ViewData["Title"] = "Nuevo Servicio";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">

        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Agregar Nuevo Servicio</h5>
            </div>

            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="strValor" class="form-label">Nombre</label>
                        <input asp-for="strValor" class="form-control" placeholder="Nombre del servicio" />
                        <span asp-validation-for="strValor" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Descripción del servicio"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


