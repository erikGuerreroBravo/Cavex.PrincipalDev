@{
    ViewData["Title"] = "Acceso denegado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Grupo CAVEX</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Importamos solo lo necesario -->
    <link rel="stylesheet" href="~/css/layout-principal.css" />
    <link rel="stylesheet" href="~/css/componentes.css" />
    <link rel="stylesheet" href="~/css/pantalla-login.css" />
    <link rel="stylesheet" href="~/css/responsivo.css" />
</head>
<body>
    <main class="cavex-container">
        <div class="login-shell">
            <div class="login-card text-center">
                <img class="login-logo" src="~/img/cavex-logo.png" alt="Grupo CAVEX" />
                <span class="eyebrow justify-content-center mt-3">Seguridad</span>
                <h1 class="cavex-title">Acceso denegado</h1>
                <p class="cavex-subtitle mb-4">Tu usuario no tiene permisos para abrir esta sección.</p>
                <a class="btn btn-cavex" asp-controller="Home" asp-action="Index">Volver al panel</a>
            </div>
        </div>
    </main>
</body>
</html>




