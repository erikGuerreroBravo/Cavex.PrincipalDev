@{
    ViewData["Title"] = "Servicios";
}

<partial name="_PageHeader"  />

<div class="cavex-card table-module">
    <partial name="_TableCardHeader"  />
    <div class="table-responsive">
        <table class="table table-hover align-middle table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Asistencia requerida por defecto</th>
                    <th>Tarifa adicional (MXN)</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="cotizacion-main-text">Traslado Sencillo</div>
                    </td>
                    <td>No</td>
                    <td>$0.00</td>
                    <td><span class="badge-active">Activo</span></td>
                    <td class="text-end">
                        <a href="/Servicios/Edit/1" class="btn btn-sm btn-outline-cavex">Editar</a>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div class="cotizacion-main-text">Traslado con Asistencia</div>
                    </td>
                    <td>Sí</td>
                    <td>$200.00</td>
                    <td><span class="badge-active">Activo</span></td>
                    <td class="text-end">
                        <a href="/Servicios/Edit/2" class="btn btn-sm btn-outline-cavex">Editar</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>


