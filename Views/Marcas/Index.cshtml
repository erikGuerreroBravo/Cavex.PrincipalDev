@model Cavex.Principal.Models.VehCatMarcaVehiculo.VehCatMarcaVehiculoSaveDto;
@{
    ViewBag.Title = "Nueva Marca";
    ViewBag.HeaderEyebrow = "Configuración";
    ViewBag.HeaderTitle = "Nueva Marca";
    ViewBag.HeaderSubtitle = "Administra el catálogo de marcas de vehículos de la plataforma.";

    ViewBag.TableTitle = "Listado de marcas";
    ViewBag.TableSubtitle = "Catálogo de marcas de vehículos y sus descripciones.";
    ViewBag.TableCount = 0;
    ViewBag.TableCountLabel = "marcas";
    ViewBag.TableExtraPill = "Catálogo General";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-servicios.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <span class="eyebrow">Formulario</span>
            <h2 class="filter-title" id="formTitle">Registrar marca</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripción de la marca.</p>
        </div>
    </div>

    <form id="formMarca" class="filter-form-compact" onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombre">Nombre de la marca</label>
                <input id="strNombre" name="StrValor" class="form-control no-uppercase" placeholder="Ej. Ford" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre de la marca es obligatorio.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcion">Descripción (Opcional)</label>
                <textarea id="strDescripcion" name="StrDescripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Vehículos de pasajeros y carga" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripción contiene caracteres no válidos.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar marca</button>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />

    <div class="table-filter-bar d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div></div>
        <div class="table-search-box position-relative" style="max-width: 260px;">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar marca..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre de la marca</th>
                    <th>Descripción</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="marcasTableBody">
                <!-- Generado dinámicamente -->
            </tbody>
        </table>
    </div>

    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegación de marcas">
            <ul class="pagination pagination-cavex m-0" id="paginationList">
                <!-- Generado dinámicamente -->
            </ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vista-marcas.js" asp-append-version="true"></script>
}
