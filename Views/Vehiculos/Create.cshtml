@{
    ViewData["Title"] = "Registro de vehículo";
    ViewData["HeaderEyebrow"] = "Inventario vehicular";
    ViewData["HeaderTitle"] = "Registro de vehículo";
    ViewData["HeaderSubtitle"] = "Captura los datos de la unidad con la estructura de VehDatosGenerales.";
    ViewData["HeaderBadgeText"] = "Frontend preparado";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-vehiculos.css" asp-append-version="true" />
}

<!-- Header compartido; el badge aclara que esta captura aún no ejecuta un POST. -->
<partial name="_PageHeader" />

<!-- Formulario principal de dbo.VehDatosGenerales.
     IDs, names, restricciones y reglas de validación se conservan como contrato futuro del backend. -->
<form id="vehiculoForm" class="vehiculo-form vehiculo-create-form vehiculo-module-form" novalidate>
    <div class="vehiculo-form-grid">
        <div class="vehiculo-main-column">
            <!-- Datos principales: columnas de identificación de dbo.VehDatosGenerales. -->
            <div class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">1</span>Datos principales</h3>
                <div class="row g-3">
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="strNumSerie">Número de serie / VIN</label>
                        <input id="strNumSerie" name="strNumSerie" maxlength="20" pattern="[A-Za-z0-9]+" class="form-control" placeholder="Ej. 3N1AB7AP0HY000001" autocomplete="off" required />
                        <div class="invalid-feedback" id="strNumSerieError">El número de serie es obligatorio.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatMarcaVehiculo">Marca</label>
                        <select id="idVehCatMarcaVehiculo" name="idVehCatMarcaVehiculo" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatMarcaVehiculoError">Selecciona una marca.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="strModelo">Modelo</label>
                        <input id="strModelo" name="strModelo" maxlength="250" class="form-control no-uppercase" placeholder="Ej. RAV4" required />
                        <div class="invalid-feedback" id="strModeloError">El modelo es obligatorio.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="intAnio">Año</label>
                        <input id="intAnio" name="intAnio" type="number" min="1990" step="1" class="form-control" required />
                        <div class="invalid-feedback" id="intAnioError">Captura un año válido.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="strVersion">Versión <span class="vehiculo-optional-label">Opcional</span></label>
                        <input id="strVersion" name="strVersion" maxlength="250" class="form-control no-uppercase" placeholder="Ej. XLE, Sport, Titanium, LTZ…" />
                        <div class="invalid-feedback" id="strVersionError">La versión no debe superar 250 caracteres.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="strPlaca">Placa</label>
                        <input id="strPlaca" name="strPlaca" maxlength="20" pattern="[A-Za-z0-9-]+" class="form-control" placeholder="ABC-123-D" autocomplete="off" required />
                        <div class="invalid-feedback" id="strPlacaError">La placa es obligatoria.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="intNumMotor">Número de motor <span class="vehiculo-optional-label">Opcional</span></label>
                        <input id="intNumMotor" name="intNumMotor" type="number" min="0" max="2147483647" step="1" class="form-control" placeholder="123456" autocomplete="off" />
                        <div class="invalid-feedback" id="intNumMotorError">Captura un número de motor entero no negativo.</div>
                    </div>
                </div>
            </div>

            <!-- Características: claves foráneas representadas por selects nativos.
                 JavaScript carga datos simulados; un GET de catálogos reemplazará esa fuente. -->
            <div class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">2</span>Características</h3>
                <div class="row g-3">
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatColor">Color</label>
                        <select id="idVehCatColor" name="idVehCatColor" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatColorError">Selecciona un color.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatTipoVehiculo">Tipo de vehículo</label>
                        <select id="idVehCatTipoVehiculo" name="idVehCatTipoVehiculo" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatTipoVehiculoError">Selecciona un tipo de vehículo.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatCapacidad">Capacidad</label>
                        <select id="idVehCatCapacidad" name="idVehCatCapacidad" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatCapacidadError">Selecciona una capacidad.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatTipoCombustible">Tipo de combustible</label>
                        <select id="idVehCatTipoCombustible" name="idVehCatTipoCombustible" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatTipoCombustibleError">Selecciona un tipo de combustible.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="decKilometrajeActual">Kilometraje actual</label>
                        <input id="decKilometrajeActual" name="decKilometrajeActual" type="number" min="0" max="999999" step="1" value="0" class="form-control" required />
                        <div class="invalid-feedback" id="decKilometrajeActualError">El kilometraje es obligatorio.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="idVehCatStatus">Estatus</label>
                        <select id="idVehCatStatus" name="idVehCatStatus" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="idVehCatStatusError">Selecciona un estatus.</div>
                    </div>
                </div>
            </div>

            <!-- Foto y observaciones: campos opcionales y fecha automática de la tabla. -->
            <div class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">3</span>Foto y observaciones</h3>
                <div class="vehiculo-media-grid">
                    <div class="vehiculo-upload-column">
                        <label class="form-label" for="vehiculoFotoArchivo">Foto del vehículo <span class="vehiculo-optional-label">Opcional</span></label>
                        <div class="vehiculo-upload-area" id="vehiculoUploadArea" role="button" tabindex="0">
                            <!-- Este archivo solo genera una vista previa local. El backend futuro subirá el archivo y asignará su URL o ruta a strUrlFoto. -->
                            <input id="vehiculoFotoArchivo" type="file" class="vehiculo-file-input" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                            <input id="strUrlFoto" name="strUrlFoto" type="hidden" value="" />
                            <div class="vehiculo-upload-prompt" id="vehiculoUploadPrompt">
                                <span class="vehiculo-upload-icon" aria-hidden="true">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                                </span>
                                <strong>Arrastra una imagen aquí</strong>
                                <span>o haz clic para seleccionar</span>
                                <small>JPG, JPEG, PNG o WEBP · máximo 5 MB</small>
                            </div>
                            <div class="vehiculo-file-preview" id="vehiculoFilePreview" hidden>
                                <img id="vehiculoUploadImage" alt="Previsualización de imagen del vehículo" />
                                <div class="vehiculo-file-meta">
                                    <strong id="vehiculoFileName">Imagen seleccionada</strong>
                                    <small>Vista previa local; aún no se genera strUrlFoto</small>
                                </div>
                                <div class="vehiculo-file-actions">
                                    <button type="button" class="btn btn-outline-cavex btn-sm" id="btnCambiarImagen">Cambiar</button>
                                    <button type="button" class="btn btn-outline-cavex btn-sm" id="btnQuitarImagen">Quitar</button>
                                </div>
                            </div>
                        </div>
                        <div class="invalid-feedback vehiculo-upload-error" id="vehiculoFotoArchivoError"></div>
                    </div>

                    <!-- dteFechaRegistro se completa con la fecha local y no admite captura manual. -->
                    <div class="vehiculo-system-data">
                        <div class="vehiculo-system-data-icon" aria-hidden="true">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        </div>
                        <div class="vehiculo-system-data-content">
                            <span class="vehiculo-system-kicker">Dato automático del sistema</span>
                            <label class="form-label" for="dteFechaRegistro">Fecha de registro</label>
                            <input id="dteFechaRegistro" name="dteFechaRegistro" type="date" class="form-control" readonly required aria-describedby="fechaRegistroAyuda" />
                            <small id="fechaRegistroAyuda">Se asigna automáticamente al registrar el vehículo.</small>
                        </div>
                    </div>

                    <div class="vehiculo-observations">
                        <label class="form-label" for="strObservaciones">Observaciones <span class="vehiculo-optional-label">Opcional</span></label>
                        <textarea id="strObservaciones" name="strObservaciones" maxlength="500" rows="4" class="form-control no-uppercase" placeholder="Comentarios internos sobre la unidad, condiciones o notas de operación."></textarea>
                        <div class="invalid-feedback" id="strObservacionesError">Las observaciones no deben superar 500 caracteres.</div>
                        <div class="vehiculo-character-counter" aria-live="polite"><span id="observacionesCounter">0</span>/500</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vista previa lateral: usa el texto visible de cada catálogo. -->
        <aside class="vehiculo-side-panel">
            <div class="summary-panel vehiculo-preview-card">
                <div class="vehiculo-preview-heading">
                    <div><span class="dashboard-kicker">Vista previa</span><h3>Resumen de la unidad</h3></div>
                    <span class="vehiculo-preview-live">En vivo</span>
                </div>
                <div class="vehicle-photo-preview" id="vehiculoFotoPreview">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9L18 10l-2-4H8l-2 4-2.5 1.1C2.7 11.4 2 12.1 2 13v3c0 .6.4 1 1 1h2" /><circle cx="7" cy="17" r="2" /><circle cx="17" cy="17" r="2" /></svg>
                </div>
                <div class="vehiculo-summary-list">
                    <div class="vehiculo-summary-item"><span>Unidad</span><strong id="previewUnidad">Sin datos</strong></div>
                    <div class="vehiculo-summary-item"><span>Versión</span><strong id="previewVersion">No especificada</strong></div>
                    <div class="vehiculo-summary-item"><span>Serie</span><strong id="previewSerie">Sin serie</strong></div>
                    <div class="vehiculo-summary-item"><span>Placa</span><strong id="previewPlaca">Sin placa</strong></div>
                    <div class="vehiculo-summary-item"><span>Color</span><strong id="previewColor">Sin seleccionar</strong></div>
                    <div class="vehiculo-summary-item"><span>Tipo</span><strong id="previewTipoVehiculo">Sin seleccionar</strong></div>
                    <div class="vehiculo-summary-item"><span>Capacidad</span><strong id="previewCapacidad">Sin seleccionar</strong></div>
                    <div class="vehiculo-summary-item"><span>Combustible</span><strong id="previewCombustible">Sin seleccionar</strong></div>
                    <div class="vehiculo-summary-item"><span>Kilometraje</span><strong id="previewKilometraje">0 km</strong></div>
                    <div class="vehiculo-summary-item vehiculo-summary-status"><span>Estatus</span><strong id="previewEstatus" class="badge-active">Activo</strong></div>
                </div>
                <div class="protected-alert mt-3 mb-0">Captura simulada. No se guardará en base de datos.</div>
            </div>
        </aside>
    </div>

    <!-- Acciones del formulario; el submit solo valida hasta contar con POST /api/vehiculos. -->
    <div class="form-action-bar vehiculo-action-bar">
        <a class="btn btn-outline-cavex" asp-controller="Vehiculos" asp-action="Index">Cancelar / Volver</a>
        <button type="button" class="btn btn-outline-cavex" id="btnLimpiarVehiculo">Limpiar</button>
        <button type="submit" class="btn btn-cavex">Guardar vehículo</button>
    </div>
</form>

@section Scripts {
    <script src="~/js/vista-vehiculos.js" asp-append-version="true"></script>
}
