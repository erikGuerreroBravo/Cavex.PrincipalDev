@{
    ViewData["Title"] = "Detalle del Vehículo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-detalle-vehiculos.css" asp-append-version="true" />
}

<!-- Ruta / Breadcrumbs -->
<div class="breadcrumb-container">
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <span class="breadcrumb-separator">&gt;</span>
    <a href="#">Vehículos</a>
    <span class="breadcrumb-separator">&gt;</span>
    <span class="breadcrumb-active">Detalle del Vehículo</span>
</div>

<div id="skeleton-wrapper">
    <!-- 1. CARD PRINCIPAL SKELETON -->
    <div class="vehicle-detail-card">
        <!-- Imagen del vehículo skeleton -->
        <div class="vehicle-image-wrapper">
            <div class="skeleton-image skeleton-shimmer"></div>
        </div>

        <!-- Contenido skeleton -->
        <div class="vehicle-info-content">
            <!-- Cabecera row -->
            <div class="vehicle-header-row">
                <div class="vehicle-title-area">
                    <div class="skeleton-title skeleton-shimmer"></div>
                    <div class="skeleton-pill skeleton-shimmer"></div>
                    <div class="skeleton-pill skeleton-shimmer"></div>
                </div>
                <div class="vehicle-actions">
                    <div class="skeleton-button skeleton-shimmer"></div>
                    <div class="skeleton-button skeleton-shimmer"></div>
                    <div class="skeleton-button skeleton-shimmer" style="width: 130px;"></div>
                </div>
            </div>

            <!-- Grid 3 columnas -->
            <div class="vehicle-details-grid">
                <!-- Columna 1 -->
                <div class="info-column">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 0 ? "160px" : i == 3 ? "150px" : "110px");"></div>
                        </div>
                    }
                </div>
                <!-- Columna 2 -->
                <div class="info-column">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 2 ? "120px" : "90px");"></div>
                        </div>
                    }
                </div>
                <!-- Columna 3 -->
                <div class="info-column">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 2 ? "160px" : "100px");"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BARRA DE PESTAÑAS SKELETON -->
    <div class="tabs-container">
        @for(int i = 0; i < 8; i++) {
            <div class="skeleton-button skeleton-shimmer" style="width: 110px; height: 35px; border-radius: 6px 6px 0 0;"></div>
        }
    </div>

    <!-- 3. METRICAS / SECCIONES SKELETON -->
    <div class="metrics-row">
        @for (int cardIdx = 0; cardIdx < 5; cardIdx++)
        {
            <div class="metric-card">
                <div class="metric-card-header">
                    <div class="skeleton-metric-icon skeleton-shimmer"></div>
                    <div class="skeleton-metric-title skeleton-shimmer"></div>
                </div>
                <div class="metric-card-body">
                    @if (cardIdx == 2) /* Estado General */
                    {
                        <div class="gauge-container">
                            <div class="skeleton-circle-progress skeleton-shimmer"></div>
                            <div class="skeleton-metric-title skeleton-shimmer" style="width: 70px;"></div>
                        </div>
                        <div class="skeleton-metric-subtext skeleton-shimmer" style="width: 140px;"></div>
                    }
                    else if (cardIdx == 4) /* Alertas */
                    {
                        <div class="alerts-list">
                            @for (int a = 0; a < 3; a++)
                            {
                                <div class="skeleton-alert-item skeleton-shimmer"></div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="skeleton-metric-label skeleton-shimmer"></div>
                        <div class="skeleton-metric-value skeleton-shimmer"></div>
                        <div class="skeleton-metric-subtext skeleton-shimmer"></div>
                    }
                </div>
                @if (cardIdx != 2)
                {
                    <div class="metric-card-footer">
                        <div class="skeleton-metric-button skeleton-shimmer"></div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div id="data-wrapper" class="fade-in" style="display: none;">
    <!-- 1. CARD PRINCIPAL DETALLE (Siempre visible) -->
    <div class="vehicle-detail-card">
        <!-- Imagen del vehículo -->
        <div class="vehicle-image-wrapper">
            <img class="vehicle-image" src="~/img/toyota_rav4.png" alt="Toyota RAV4 2021" />
        </div>

        <!-- Contenido real -->
        <div class="vehicle-info-content">
            <!-- Cabecera con Título, Estado y Acciones -->
            <div class="vehicle-header-row">
                <div class="vehicle-title-area">
                    <h2 class="vehicle-title">Toyota RAV4 2021</h2>
                    <span class="badge-plate">ABC-123-D</span>
                    <span class="badge-status-active">Activo</span>
                </div>
                <div class="vehicle-actions">
                    <a href="#" class="btn-action-outline">
                        <img src="~/svg/vista-detalles-vehiculos/edit.svg" width="14" height="14" class="btn-icon" alt="Editar" />
                        Editar
                    </a>
                    <a href="#" class="btn-action-outline">
                        <img src="~/svg/vista-detalles-vehiculos/history.svg" width="14" height="14" class="btn-icon" alt="Historial" />
                        Historial
                    </a>
                    <a href="#" class="btn-action-primary">
                        <img src="~/svg/vista-detalles-vehiculos/plus.svg" width="14" height="14" class="btn-icon" style="filter: brightness(0) invert(1);" alt="Nuevo" />
                        Nuevo Servicio
                    </a>
                </div>
            </div>

            <!-- Grid de detalles (3 Columnas) -->
            <div class="vehicle-details-grid">
                <!-- Columna 1 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">VIN:</span>
                        <span class="info-value">JTMWFREV5JJ123456</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Cliente:</span>
                        <span class="info-value">Juan Pérez López</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Teléfono:</span>
                        <span class="info-value">55 1234 5678</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email:</span>
                        <span class="info-value">juan.perez@email.com</span>
                    </div>
                </div>

                <!-- Columna 2 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">Año:</span>
                        <span class="info-value">2021</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Color:</span>
                        <span class="info-value">Blanco Perlado</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Motor:</span>
                        <span class="info-value">2.5L 4 Cilindros</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Transmisión:</span>
                        <span class="info-value">Automática</span>
                    </div>
                </div>

                <!-- Columna 3 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">Kilometraje:</span>
                        <span class="info-value">45,230 km</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Fecha de compra:</span>
                        <span class="info-value">10/03/2021</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Garantía:</span>
                        <span class="info-value">Vigente hasta 10/03/2026</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BARRA DE NAVEGACIÓN POR PESTAÑAS (Tabs - Visibles pero sin comportamiento reactivo a sub-vistas) -->
    <div class="tabs-container">
        <button class="tab-btn active" data-tab="resumen">
            <img src="~/svg/vista-detalles-vehiculos/car.svg" width="16" height="16" alt="Resumen" />
            Resumen
        </button>
        <button class="tab-btn" data-tab="mantenimiento">
            <img src="~/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Mantenimiento" />
            Mantenimiento
        </button>
        <button class="tab-btn" data-tab="revision">
            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="16" height="16" alt="Revisión" />
            Revisión 24 Puntos
        </button>
        <button class="tab-btn" data-tab="llantas">
            <img src="~/svg/vista-detalles-vehiculos/wheel.svg" width="16" height="16" alt="Llantas" />
            Llantas
        </button>
        <button class="tab-btn" data-tab="seguro">
            <img src="~/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguro" />
            Seguro
        </button>
        <button class="tab-btn" data-tab="infracciones">
            <img src="~/svg/vista-detalles-vehiculos/warning.svg" width="16" height="16" alt="Infracciones" />
            Infracciones
        </button>
        <button class="tab-btn" data-tab="documentos">
            <img src="~/svg/vista-detalles-vehiculos/folder.svg" width="16" height="16" alt="Documentos" />
            Documentos
        </button>
        <button class="tab-btn" data-tab="historial">
            <img src="~/svg/vista-detalles-vehiculos/history.svg" width="16" height="16" alt="Historial" />
            Historial
        </button>
    </div>

    <!-- CONTENIDO PESTAÑA: Resumen -->
    <div id="tab-resumen" class="tab-content">
        <!-- Fila de Métricas Reales -->
        <div class="metrics-row">
        <!-- Card 1: Próximo Servicio -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/calendar.svg" width="16" height="16" alt="Calendario" />
                </span>
                <h4 class="metric-card-title">Próximo Servicio</h4>
            </div>
            <div class="metric-card-body">
                <span class="metric-card-label">Servicio Programado</span>
                <span class="metric-card-value">15/06/2024</span>
                <span class="metric-card-subtext">en 2,350 km</span>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver detalle</a>
            </div>
        </div>

        <!-- Card 2: Último Servicio -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Mantenimiento" />
                </span>
                <h4 class="metric-card-title">Último Servicio</h4>
            </div>
            <div class="metric-card-body">
                <span class="metric-card-label">Servicio Mayor</span>
                <span class="metric-card-value">10/03/2024</span>
                <span class="metric-card-subtext">hace 1,200 km</span>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver historial</a>
            </div>
        </div>

        <!-- Card 3: Estado General -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguridad" />
                </span>
                <h4 class="metric-card-title">Estado General</h4>
            </div>
            <div class="metric-card-body">
                <div class="gauge-container">
                    <div class="progress-ring-gauge-68">
                        <span class="progress-ring-text-68">92%</span>
                    </div>
                    <span class="gauge-status-label" style="color: var(--exito);">Excelente</span>
                </div>
                <div class="gauge-footer-text">Todo en óptimas condiciones</div>
            </div>
        </div>

        <!-- Card 4: Kilometraje -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/speedometer.svg" width="16" height="16" alt="Kilometraje" />
                </span>
                <h4 class="metric-card-title">Kilometraje</h4>
            </div>
            <div class="metric-card-body">
                <span class="metric-card-value" style="font-size: 23px; margin-bottom: 6px;">45,230 km</span>
                <span class="metric-card-subtext">Promedio: 12,450 km/año</span>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver tendencias</a>
            </div>
        </div>

        <!-- Card 5: Alertas -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon metric-icon-red">
                    <img src="~/svg/vista-detalles-vehiculos/bell.svg" width="16" height="16" alt="Alertas" />
                </span>
                <h4 class="metric-card-title">Alertas</h4>
            </div>
            <div class="metric-card-body">
                <div class="alerts-list">
                    <div class="alert-item">
                        <div class="alert-left">
                            <span class="alert-dot alert-dot-warning" title="Próximo"></span>
                            <span class="alert-msg">Cambio de aceite</span>
                        </div>
                        <span class="alert-meta">en 2,350 km</span>
                    </div>
                    <div class="alert-item">
                        <div class="alert-left">
                            <span class="alert-dot alert-dot-warning" title="Próximo"></span>
                            <span class="alert-msg">Verificación</span>
                        </div>
                        <span class="alert-meta">30/06/24</span>
                    </div>
                    <div class="alert-item">
                        <div class="alert-left">
                            <span class="alert-dot alert-dot-danger" title="Urgente"></span>
                            <span class="alert-msg">Seguro vence</span>
                        </div>
                        <span class="alert-meta">15/07/24</span>
                    </div>
                </div>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver todas las alertas</a>
            </div>
        </div>
    </div>

    <!-- Fila de Secciones Secundarias Reales -->
    <div class="secondary-row">
        <!-- Mantenimiento Reciente -->
        <div class="secondary-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Herramienta" />
                </span>
                <h4 class="secondary-card-title">Mantenimiento Reciente</h4>
            </div>
            <div class="maint-list">
                <!-- Cabecera de columnas alineada -->
                <div class="maint-item-header">
                    <span>Servicio</span>
                    <span>Fecha</span>
                    <span>Kilometraje</span>
                    <span style="text-align: right;">Estado</span>
                </div>

                <div class="maint-item">
                    <div class="maint-left">
                        <span class="maint-icon maint-icon-orange">
                            <img src="~/svg/vista-detalles-vehiculos/dollar.svg" width="11" height="11" alt="Dinero" />
                        </span>
                        <span class="maint-name">Cambio de Aceite y Filtro</span>
                    </div>
                    <span class="maint-date">10/03/2024</span>
                    <span class="maint-km">45,230 km</span>
                    <div class="maint-status">
                        <span class="badge-status-completed">Completado</span>
                    </div>
                </div>
                <div class="maint-item">
                    <div class="maint-left">
                        <span class="maint-icon maint-icon-yellow">
                            <img src="~/svg/vista-detalles-vehiculos/wrench.svg" width="11" height="11" alt="Mecánico" />
                        </span>
                        <span class="maint-name">Revisión de Frenos (Balatas)</span>
                    </div>
                    <span class="maint-date">10/03/2024</span>
                    <span class="maint-km">45,230 km</span>
                    <div class="maint-status">
                        <span class="badge-status-completed">Completado</span>
                    </div>
                </div>
                <div class="maint-item">
                    <div class="maint-left">
                        <span class="maint-icon maint-icon-blue">
                            <img src="~/svg/vista-detalles-vehiculos/speedometer.svg" width="11" height="11" alt="Llantas" />
                        </span>
                        <span class="maint-name">Rotación de Llantas</span>
                    </div>
                    <span class="maint-date">10/03/2024</span>
                    <span class="maint-km">45,230 km</span>
                    <div class="maint-status">
                        <span class="badge-status-completed">Completado</span>
                    </div>
                </div>
                <div class="maint-item">
                    <div class="maint-left">
                        <span class="maint-icon maint-icon-purple">
                            <img src="~/svg/vista-detalles-vehiculos/shield.svg" width="11" height="11" alt="Alineación" />
                        </span>
                        <span class="maint-name">Alineación y Balanceo</span>
                    </div>
                    <span class="maint-date">10/03/2024</span>
                    <span class="maint-km">45,230 km</span>
                    <div class="maint-status">
                        <span class="badge-status-completed">Completado</span>
                    </div>
                </div>
                <div class="maint-item">
                    <div class="maint-left">
                        <span class="maint-icon maint-icon-blue">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="11" height="11" alt="Aprobado" />
                        </span>
                        <span class="maint-name">Revisión 24 Puntos</span>
                    </div>
                    <span class="maint-date">10/03/2024</span>
                    <span class="maint-km">45,230 km</span>
                    <div class="maint-status">
                        <span class="badge-status-completed">Completado</span>
                    </div>
                </div>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver historial completo</a>
            </div>
        </div>

        <!-- Revisión 24 Puntos -->
        <div class="secondary-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/check.svg" width="16" height="16" alt="Revisado" />
                </span>
                <h4 class="secondary-card-title">Revisión 24 Puntos (Última)</h4>
            </div>
            <div class="revision-body">
                <div class="revision-gauge progress-ring-gauge-110">
                    <div class="revision-gauge-text">
                        <span class="rev-num">24/24</span>
                        <span class="rev-lbl">Aprobados</span>
                        <span class="rev-status">Excelente</span>
                    </div>
                </div>
                <div class="revision-checklist">
                    <div class="check-item">
                        <span class="check-icon">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="12" height="12" alt="Aprobado" />
                        </span>
                        <span>Sistema de Frenos</span>
                    </div>
                    <div class="check-item">
                        <span class="check-icon">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="12" height="12" alt="Aprobado" />
                        </span>
                        <span>Dirección y Suspensión</span>
                    </div>
                    <div class="check-item">
                        <span class="check-icon">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="12" height="12" alt="Aprobado" />
                        </span>
                        <span>Luces y Eléctrico</span>
                    </div>
                    <div class="check-item">
                        <span class="check-icon">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="12" height="12" alt="Aprobado" />
                        </span>
                        <span>Niveles de Fluidos</span>
                    </div>
                    <div class="check-item">
                        <span class="check-icon">
                            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="12" height="12" alt="Aprobado" />
                        </span>
                        <span>Llantas y Rines</span>
                    </div>
                    <div class="check-more">... y 19 puntos más</div>
                </div>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver reporte completo</a>
            </div>
        </div>

        <!-- Stack de Seguro e Infracciones -->
        <div class="right-panel-stack">
            <div class="secondary-card seguro-card">
                <div class="secondary-card-header">
                    <span class="metric-icon">
                        <img src="~/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguridad" />
                    </span>
                    <h4 class="secondary-card-title">Seguro Vigente</h4>
                </div>
                <div class="seguro-body">
                    <div class="logo-seguro">
                        <span class="qualitas-q-logo">Q</span>
                    </div>
                    <div class="seguro-info">
                        <span class="seguro-provider">Qualitas</span>
                        <div class="seguro-detail">Póliza: <span>1234567890</span></div>
                        <div class="seguro-detail">Cobertura: <span>Amplia</span></div>
                        <div class="seguro-detail">Vigencia: <span>15/07/23 - 15/07/24</span></div>
                    </div>
                </div>
                <div class="seguro-badge-row">
                    <span class="badge-seguro-vigente">Vigente (45 días restantes)</span>
                </div>
                <div class="metric-card-footer">
                    <a href="#" class="btn-metric-outline">Ver detalles</a>
                </div>
            </div>

            <div class="secondary-card infracciones-card">
                <div class="infracciones-header">
                    <span class="metric-icon metric-icon-red">
                        <img src="~/svg/vista-detalles-vehiculos/warning.svg" width="16" height="16" alt="Advertencia" />
                    </span>
                    <h5 class="infracciones-title">Infracciones</h5>
                </div>
                <div class="infracciones-body">
                    <div class="infracciones-left">
                        <span class="infracciones-count">2</span>
                        <div style="display: flex; flex-direction: column;">
                            <span class="infracciones-desc">Infracciones activas</span>
                            <span class="infracciones-amount">Total adeudado: <span>$1,450.00</span></span>
                        </div>
                    </div>
                    <a href="#" class="btn-infracciones-detail">Ver detalle</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Fila Inferior Reales (Gráfico y Docs de Resumen) -->
    <div class="bottom-row">
        <div class="secondary-card bottom-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/speedometer.svg" width="16" height="16" alt="Gráfico" />
                </span>
                <h4 class="secondary-card-title">Historial de Kilometraje</h4>
            </div>
            <div style="flex-grow: 1; position: relative; height: 220px; width: 100%;">
                <canvas id="mileageChart"></canvas>
            </div>
        </div>

        <div class="secondary-card bottom-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="~/svg/vista-detalles-vehiculos/folder.svg" width="16" height="16" alt="Documentos" />
                </span>
                <h4 class="secondary-card-title">Documentos</h4>
            </div>
            <div class="doc-list">
                <div class="doc-item">
                    <div class="doc-left">
                        <span class="doc-icon">
