
@{
    ViewData["Title"] = "Detalle del Vehículo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-detalle-vehiculos.css" asp-append-version="true" />
}

<!-- Ruta / Breadcrumbs y Botón Regresar -->
<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div class="breadcrumb-container m-0">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span class="breadcrumb-separator">&gt;</span>
        <a asp-controller="Vehiculos" asp-action="Index">Vehículos</a>
        <span class="breadcrumb-separator">&gt;</span>
        <span class="breadcrumb-active">Detalles del Vehículo</span>
    </div>
    <a asp-controller="Vehiculos" asp-action="Index" class="btn btn-outline-cavex rounded-pill px-3 py-2 btn-sm d-inline-flex align-items-center" style="font-weight: 750; border: 1px solid rgba(0, 140, 149, 0.18); background: white; color: var(--azul-cavex); transition: all 0.2s ease-in-out;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1" style="vertical-align: -2px;"><polyline points="15 18 9 12 15 6"/></svg>
        Volver al listado
    </a>
</div>
    
<div id="skeleton-wrapper">
    <!-- 1. CARD PRINCIPAL SKELETON -->
    <div class="vehicle-detail-card">
        <!-- Imagen del vehículo skeleton -->
        <div class="vehicle-image-wrapper">
            <div class="skeleton-image skeleton-shimmer"></div>
        </div>

        <!-- Contenido skeleton -->
        <div class="vehicle-info-content">
            <!-- Cabecera row -->
            <div class="vehicle-header-row">
                <div class="vehicle-title-area">
                    <div class="skeleton-title skeleton-shimmer"></div>
                    <div class="skeleton-pill skeleton-shimmer"></div>
                    <div class="skeleton-pill skeleton-shimmer"></div>
                </div>
                <div class="vehicle-actions">
                    <div class="skeleton-button skeleton-shimmer"></div>
                    <div class="skeleton-button skeleton-shimmer"></div>
                    <div class="skeleton-button skeleton-shimmer" style="width: 130px;"></div>
                </div>
            </div>

            <!-- Grid 3 columnas -->
            <div class="vehicle-details-grid">
                <!-- Columna 1 -->
                <div class="info-column">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 0 ? "160px" : i == 3 ? "150px" : "110px");"></div>
                        </div>
                    }
                </div>
                <!-- Columna 2 -->
                <div class="info-column">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 2 ? "120px" : "90px");"></div>
                        </div>
                    }
                </div>
                <!-- Columna 3 -->
                <div class="info-column">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="info-item">
                            <div class="skeleton-label skeleton-shimmer" style="margin-right: 15px;"></div>
                            <div class="skeleton-value skeleton-shimmer" style="width: @(i == 2 ? "160px" : "100px");"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BARRA DE PESTAÑAS SKELETON -->
    <div class="tabs-container">
        @for(int i = 0; i < 8; i++) {
            <div class="skeleton-button skeleton-shimmer" style="width: 110px; height: 35px; border-radius: 6px 6px 0 0;"></div>
        }
    </div>

    <!-- 3. METRICAS / SECCIONES SKELETON -->
    <div class="metrics-row">
        @for (int cardIdx = 0; cardIdx < 5; cardIdx++)
        {
            <div class="metric-card">
                <div class="metric-card-header">
                    <div class="skeleton-metric-icon skeleton-shimmer"></div>
                    <div class="skeleton-metric-title skeleton-shimmer"></div>
                </div>
                <div class="metric-card-body">
                    @if (cardIdx == 2) /* Estado General */
                    {
                        <div class="gauge-container">
                            <div class="skeleton-circle-progress skeleton-shimmer"></div>
                            <div class="skeleton-metric-title skeleton-shimmer" style="width: 70px;"></div>
                        </div>
                        <div class="skeleton-metric-subtext skeleton-shimmer" style="width: 140px;"></div>
                    }
                    else if (cardIdx == 4) /* Alertas */
                    {
                        <div class="alerts-list">
                            @for (int a = 0; a < 3; a++)
                            {
                                <div class="skeleton-alert-item skeleton-shimmer"></div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="skeleton-metric-label skeleton-shimmer"></div>
                        <div class="skeleton-metric-value skeleton-shimmer"></div>
                        <div class="skeleton-metric-subtext skeleton-shimmer"></div>
                    }
                </div>
                @if (cardIdx != 2)
                {
                    <div class="metric-card-footer">
                        <div class="skeleton-metric-button skeleton-shimmer"></div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div id="data-wrapper" class="fade-in" style="display: none;">
    <!-- 1. CARD PRINCIPAL DETALLE (Siempre visible) -->
    <div class="vehicle-detail-card">
        <!-- Imagen del vehículo -->
        <div class="vehicle-image-wrapper">
            <img class="vehicle-image" id="det-foto" src="" alt="Imagen del vehículo" />
        </div>

        <!-- Contenido real -->
        <div class="vehicle-info-content">
            <!-- Cabecera con Título, Estado y Acciones -->
            <div class="vehicle-header-row">
                <div class="vehicle-title-area">
                    <h2 class="vehicle-title" id="det-nombre">—</h2>
                    <span class="badge-plate" id="det-placa">—</span>
                    <span class="badge-status-active" id="det-estatus">—</span>
                </div>
                <div class="vehicle-actions">
                    <a href="#" class="btn-action-outline">
                        <img src="/svg/vista-detalles-vehiculos/edit.svg" width="14" height="14" class="btn-icon" alt="Editar" />
                        Editar
                    </a>
                    <a href="#" class="btn-action-outline">
                        <img src="/svg/vista-detalles-vehiculos/history.svg" width="14" height="14" class="btn-icon" alt="Historial" />
                        Historial
                    </a>
                    <a href="#" class="btn-action-primary">
                        <img src="/svg/vista-detalles-vehiculos/plus.svg" width="14" height="14" class="btn-icon" style="filter: brightness(0) invert(1);" alt="Nuevo" />
                        Nuevo Servicio
                    </a>
                </div>
            </div>

            <!-- Grid de detalles (3 Columnas) -->
            <div class="vehicle-details-grid">
                <!-- Columna 1 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">VIN:</span>
                        <span class="info-value" id="det-vin">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Tipo:</span>
                        <span class="info-value" id="det-tipo">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Combustible:</span>
                        <span class="info-value" id="det-combustible">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Capacidad:</span>
                        <span class="info-value" id="det-capacidad">—</span>
                    </div>
                </div>

                <!-- Columna 2 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">Año:</span>
                        <span class="info-value" id="det-anio">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Color:</span>
                        <span class="info-value" id="det-color">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Motor:</span>
                        <span class="info-value" id="det-motor">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Transmisión:</span>
                        <span class="info-value" id="det-transmision">—</span>
                    </div>
                </div>

                <!-- Columna 3 -->
                <div class="info-column">
                    <div class="info-item">
                        <span class="info-label">Kilometraje:</span>
                        <span class="info-value" id="det-kilometraje">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Fecha de compra:</span>
                        <span class="info-value" id="det-fechacompra">—</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Garantía:</span>
                        <span class="info-value" id="det-garantia">—</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BARRA DE NAVEGACIÓN POR PESTAÑAS (Tabs - Visibles pero sin comportamiento reactivo a sub-vistas) -->
    <div class="tabs-container">
        <button class="tab-btn active" data-tab="resumen">
            <img src="~/svg/vista-detalles-vehiculos/car.svg" width="16" height="16" alt="Resumen" />
            Resumen
        </button>
        <button class="tab-btn" data-tab="mantenimiento">
            <img src="~/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Mantenimiento" />
            Mantenimiento
        </button>
        <button class="tab-btn" data-tab="revision">
            <img src="~/svg/vista-detalles-vehiculos/check.svg" width="16" height="16" alt="Revisión" />
            Revisión 24 Puntos
        </button>
        <button class="tab-btn" data-tab="llantas">
            <img src="~/svg/vista-detalles-vehiculos/wheel.svg" width="16" height="16" alt="Llantas" />
            Llantas
        </button>
        <button class="tab-btn" data-tab="seguro">
            <img src="~/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguro" />
            Seguro
        </button>
        <button class="tab-btn" data-tab="infracciones">
            <img src="~/svg/vista-detalles-vehiculos/warning.svg" width="16" height="16" alt="Infracciones" />
            Infracciones
        </button>
        <button class="tab-btn" data-tab="documentos">
            <img src="~/svg/vista-detalles-vehiculos/folder.svg" width="16" height="16" alt="Documentos" />
            Documentos
        </button>
        <button class="tab-btn" data-tab="historial">
            <img src="~/svg/vista-detalles-vehiculos/history.svg" width="16" height="16" alt="Historial" />
            Historial
        </button>
    </div>

    <!-- CONTENIDO PESTAÑA: Resumen -->
    <div id="tab-resumen" class="tab-content">
        <!-- Fila de Métricas Reales -->
        <div class="metrics-row">

        <!-- Card 1: Próximo Servicio -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/calendar.svg" width="16" height="16" alt="Calendario" />
                </span>
                <h4 class="metric-card-title">Próximo Servicio</h4>
            </div>
            <div class="metric-card-body" id="resumen-proximo-body">
                <!-- Dinámico -->
            </div>
        </div>

        <!-- Card 2: Último Servicio -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Mantenimiento" />
                </span>
                <h4 class="metric-card-title">Último Servicio</h4>
            </div>
            <div class="metric-card-body" id="resumen-ultimo-body">
                <!-- Dinámico -->
            </div>
        </div>

        <!-- Card 3: Estado General -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguridad" />
                </span>
                <h4 class="metric-card-title">Estado General</h4>
            </div>
            <div class="metric-card-body">
                <div class="gauge-container">
                    <div class="progress-ring-gauge-68">
                        <span class="progress-ring-text-68" id="resumen-salud-pct">0%</span>
                    </div>
                    <span class="gauge-status-label" id="resumen-salud-label" style="color: var(--exito);">—</span>
                </div>
                <div class="gauge-footer-text" id="resumen-salud-footer">—</div>
            </div>
        </div>

        <!-- Card 4: Kilometraje -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/speedometer.svg" width="16" height="16" alt="Kilometraje" />
                </span>
                <h4 class="metric-card-title">Kilometraje</h4>
            </div>
            <div class="metric-card-body">
                <span class="metric-card-value" id="resumen-km-actual" style="font-size: 23px; margin-bottom: 6px;">—</span>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver tendencias</a>
            </div>
        </div>

        <!-- Card 5: Alertas -->
        <div class="metric-card">
            <div class="metric-card-header">
                <span class="metric-icon metric-icon-red">
                    <img src="/svg/vista-detalles-vehiculos/bell.svg" width="16" height="16" alt="Alertas" />
                </span>
                <h4 class="metric-card-title">Alertas</h4>
            </div>
            <div class="metric-card-body">
                <div class="alerts-list" id="resumen-alertas-lista">
                    <!-- Dinámico -->
                </div>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver todas las alertas</a>
            </div>
        </div>
    </div>
</div>

    <!-- Fila de Secciones Secundarias Reales -->
    <div class="secondary-row">
        <div class="secondary-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/wrench.svg" width="16" height="16" alt="Herramienta" />
                </span>
                <h4 class="secondary-card-title">Mantenimiento Reciente</h4>
            </div>
            <div class="maint-list" id="resumen-mantenimiento-lista">
                <!-- Dinámico -->
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver historial completo</a>
            </div>
        </div>

        <!-- Revisión 24 Puntos -->
        <div class="secondary-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/check.svg" width="16" height="16" alt="Revisado" />
                </span>
                <h4 class="secondary-card-title">Revisión 24 Puntos (Última)</h4>
            </div>
            <div class="revision-body">
                <div class="revision-gauge progress-ring-gauge-110">
                    <div class="revision-gauge-text">
                        <span class="rev-num" id="resumen-revision-num">0/24</span>
                        <span class="rev-lbl">Aprobados</span>
                        <span class="rev-status" id="resumen-revision-status">—</span>
                    </div>
                </div>
                <div class="revision-checklist" id="resumen-revision-checklist">
                    <!-- Dinámico -->
                </div>
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver reporte completo</a>
            </div>
        </div>

        <!-- Stack de Seguro e Infracciones -->
        <div class="right-panel-stack">
            <div class="secondary-card seguro-card">
                <div class="secondary-card-header">
                    <span class="metric-icon">
                        <img src="/svg/vista-detalles-vehiculos/shield.svg" width="16" height="16" alt="Seguridad" />
                    </span>
                    <h4 class="secondary-card-title">Seguro Vigente</h4>
                </div>
                <div class="seguro-body">
                    <div class="logo-seguro">
                        <span class="qualitas-q-logo">Q</span>
                    </div>
                    <div class="seguro-info">
                        <span class="seguro-provider" id="resumen-seguro-provider">—</span>
                        <div class="seguro-detail" id="resumen-seguro-poliza">Póliza: <span>—</span></div>
                        <div class="seguro-detail" id="resumen-seguro-cobertura">Cobertura: <span>—</span></div>
                        <div class="seguro-detail" id="resumen-seguro-vigencia">Vigencia: <span>—</span></div>
                    </div>
                </div>
                <div class="seguro-badge-row">
                    <span class="badge-seguro-vigente" id="resumen-seguro-restante">—</span>
                </div>
                <div class="metric-card-footer">
                    <a href="#" class="btn-metric-outline">Ver detalles</a>
                </div>
            </div>

            <div class="secondary-card infracciones-card">
                <div class="infracciones-header">
                    <span class="metric-icon metric-icon-red">
                        <img src="/svg/vista-detalles-vehiculos/warning.svg" width="16" height="16" alt="Advertencia" />
                    </span>
                    <h5 class="infracciones-title">Infracciones</h5>
                </div>
                <div class="infracciones-body">
                    <div class="infracciones-left">
                        <span class="infracciones-count" id="resumen-infracciones-count">0</span>
                        <div style="display: flex; flex-direction: column;">
                            <span class="infracciones-desc">Infracciones activas</span>
                            <span class="infracciones-amount" id="resumen-infracciones-monto">Total adeudado: <span>$0.00</span></span>
                        </div>
                    </div>
                    <a href="#" class="btn-infracciones-detail">Ver detalle</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Fila Inferior Reales (Gráfico y Docs de Resumen) -->
    <div class="bottom-row">
        <div class="secondary-card bottom-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/speedometer.svg" width="16" height="16" alt="Gráfico" />
                </span>
                <h4 class="secondary-card-title">Historial de Kilometraje</h4>
            </div>
            <div style="flex-grow: 1; position: relative; height: 220px; width: 100%; display: flex; align-items: center; justify-content: center;">
                <canvas id="mileageChart"></canvas>
                <div id="mileageChartPlaceholder" style="display: none; flex-direction: column; align-items: center; justify-content: center; gap: 8px;" class="text-muted">
                    <img src="/svg/vista-detalles-vehiculos/speedometer.svg" width="32" height="32" style="opacity: 0.3;" />
                    <span class="font-weight-bold" style="color: var(--gris-oscuro);">Sin registros aún</span>
                </div>
            </div>
        </div>

        <div class="secondary-card bottom-card">
            <div class="secondary-card-header">
                <span class="metric-icon">
                    <img src="/svg/vista-detalles-vehiculos/folder.svg" width="16" height="16" alt="Documentos" />
                </span>
                <h4 class="secondary-card-title">Documentos</h4>
            </div>
            <div class="doc-list" id="resumen-documentos-lista">
                <!-- Dinámico -->
            </div>
            <div class="metric-card-footer">
                <a href="#" class="btn-metric-outline">Ver todos los documentos</a>
            </div>
        </div>
    </div>
</div>
    <!-- Fin CONTENIDO PESTAÑA: Resumen -->

    <!-- CONTENIDO PESTAÑA: Mantenimiento -->
    <div id="tab-mantenimiento" class="tab-content" style="display: none;">
        <div class="table-card">
            <!-- Sección de Tarjetas de Resumen Financiero y Métricas Ampliadas -->
            <div class="maint-stats-grid">
                <div class="maint-stats-card">
                    <div class="maint-stats-icon currency">$</div>
                    <div>
                        <span class="maint-stats-label">Inversión Total en Servicios</span>
                        <strong class="maint-stats-value" id="maint-total-cost">$0.00 MXN</strong>
                    </div>
                </div>
                <div class="maint-stats-card">
                    <div class="maint-stats-icon wrench">🛠️</div>
                    <div>
                        <span class="maint-stats-label">Servicios Registrados</span>
                        <strong class="maint-stats-value" id="maint-total-count">0 Servicios</strong>
                    </div>
                </div>
                <div class="maint-stats-card">
                    <div class="maint-stats-icon trend">📈</div>
                    <div>
                        <span class="maint-stats-label">Kilómetros Recorridos</span>
                        <strong class="maint-stats-value" id="maint-total-km">— km (Total)</strong>
                    </div>
                </div>
            </div>

            <h3 class="tab-title">Historial Completo y Detallado de Mantenimiento</h3>
            <p class="tab-desc">
                Muestra la lista de servicios realizados a este vehículo. No se muestran identificadores internos (IDs).
            </p>
            <div class="cavex-table-responsive">
                <table class="cavex-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>No. Orden / Folio</th>
                            <th>Servicio / Concepto</th>
                            <th>Trabajos Realizados y Reemplazos</th>
                            <th>Kilometraje</th>
                            <th>Taller / Proveedor</th>
                            <th>Responsable Técnico</th>
                            <th>Costo</th>
                            <th>Estado</th>
                            <th style="text-align: right;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="mantenimiento-tabla-body">
                        <!-- Dinámico -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Revisión 24 Puntos -->
    <div id="tab-revision" class="tab-content" style="display: none;">
        <div class="table-card">
            <div class="revision-header-row">
                <div>
                    <h3 class="tab-title" style="margin: 0;">Reporte Detallado de Revisión de 24 Puntos</h3>
                    <p class="tab-desc" style="margin: 4px 0 0 0;">
                        Última revisión física realizada por personal certificado. No se muestran identificadores internos (IDs).
                    </p>
                </div>
                <div class="revision-status-badge" id="revision-status-badge">
                    Estatus: —
                </div>
            </div>

            <div class="checklist-category-grid" id="revision-cats-grid">
                <!-- Dinámico -->
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Llantas -->
    <div id="tab-llantas" class="tab-content" style="display: none;">
        <div class="table-card">
            <h3 class="tab-title">Estado Avanzado de Neumáticos</h3>
            <p class="tab-desc">
                Desglose específico de las especificaciones, desgaste y vida útil por cada posición física de rodamiento en el vehículo. No se muestran identificadores internos.
            </p>

            <div class="llantas-simplified-grid" id="llantas-grid">
                <!-- Dinámico -->
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Seguro -->
    <div id="tab-seguro" class="tab-content" style="display: none;">
        <div class="table-card">
            <h3 class="tab-title">Información de Póliza de Seguro</h3>
            <p class="tab-desc">
                Consulta los detalles de la póliza de seguro activa y el historial de siniestros relacionados. No se muestran identificadores internos (IDs).
            </p>

            <div class="seguro-tab-layout">
                <div class="seguro-policy-card">
                    <div class="policy-header">
                        <div>
                            <span class="policy-provider">Póliza de Vehículo</span>
                            <h4 class="policy-title" id="seguro-proveedor">—</h4>
                        </div>
                        <div class="policy-logo-letter" id="seguro-logo-letter">—</div>
                    </div>
                    <div class="policy-details-list" id="seguro-detalles-lista">
                        <!-- Dinámico -->
                    </div>
                    <div class="policy-status-row">
                        <span class="policy-status-badge" id="seguro-status-badge">—</span>
                        <span class="policy-status-days" id="seguro-status-days">—</span>
                    </div>
                </div>

                <div class="seguro-help-card">
                    <div>
                        <h4 class="seguro-help-title">Contactos de Emergencia & Coberturas</h4>
                        <div class="seguro-help-content-list" id="seguro-help-detalles">
                            <!-- Dinámico -->
                        </div>
                    </div>
                    <div class="seguro-help-actions">
                        <a href="#" class="btn-action-outline btn-seguro-download">
                            <img src="/svg/vista-detalles-vehiculos/folder.svg" width="14" height="14" alt="Icon" /> Descargar Póliza PDF
                        </a>
                    </div>
                </div>
            </div>

            <!-- Tabla de Siniestros (Historial) -->
            <h4 style="font-size: 15px; font-weight: 750; color: var(--azul-cavex); margin-top: 24px; margin-bottom: 12px;">Historial de Siniestros Reportados</h4>
            <div class="cavex-table-responsive">
                <table class="cavex-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>No. Reporte / Folio ajustador</th>
                            <th>Tipo de Incidente</th>
                            <th>Ajustador asignado</th>
                            <th>Deducible Pagado</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody id="siniestros-tabla-body">
                        <!-- Dinámico -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Infracciones -->
    <div id="tab-infracciones" class="tab-content" style="display: none;">
        <div class="table-card">
            <div class="infracciones-header-row">
                <div>
                    <h3 class="tab-title" style="margin: 0;">Infracciones y Multas de Tránsito</h3>
                    <p class="tab-desc" style="margin: 4px 0 0 0;">
                        Control y estado de infracciones vinculadas a las placas del vehículo. No se muestran identificadores internos.
                    </p>
                </div>
                <div>
                    <span class="infracciones-amount-badge" id="infracciones-total-badge">
                        Pendiente: $0.00
                    </span>
                </div>
            </div>

            <div class="cavex-table-responsive">
                <table class="cavex-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>No. Folio Infracción</th>
                            <th>Motivo / Descripción</th>
                            <th>Lugar</th>
                            <th>Monto</th>
                            <th>Estatus Pago</th>
                            <th style="text-align: right;">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="infracciones-tabla-body">
                        <!-- Dinámico -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Documentos -->
    <div id="tab-documentos" class="tab-content" style="display: none;">
        <div class="table-card">
            <h3 class="tab-title">Expediente Digital del Vehículo</h3>
            <p class="tab-desc">
                Consulta y gestiona el expediente digital del vehículo. Puedes descargar copias vigentes o cargar documentos faltantes y actualizaciones requeridas.
            </p>

            <div class="docs-grid" id="documentos-grid">
                <!-- Dinámico -->
            </div>
        </div>
    </div>

    <!-- CONTENIDO PESTAÑA: Historial -->
    <div id="tab-historial" class="tab-content" style="display: none;">
        <div class="table-card">
            <h3 class="tab-title">Bitácora Histórica de Eventos</h3>
            <p class="tab-desc">
                Línea de tiempo cronológica con todas las actividades, mantenimientos e incidentes del vehículo. No se muestran identificadores internos.
            </p>

            <div class="timeline-list" id="historial-timeline-list">
                <!-- Dinámico -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.vehiculoId = @(ViewData["VehiculoId"] ?? 1);
    </script>
    <!-- CDN de Chart.js y plugin datalabels estáticos -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <!-- Script de lógica de negocio y transición separado del HTML -->
    <script src="~/js/vista-detalles-vehiculo.js" asp-append-version="true"></script>
}
