@model Cavex.Principal.Models.VehCatResponsableServicio.VehCatResponsableServicioSaveDto;
@{
    ViewData["Title"] = "Nuevo Responsable de Servicio";
    ViewData["HeaderEyebrow"] = "Configuracion";
    ViewData["HeaderTitle"] = "Nuevo Responsable de Servicio";
    ViewData["HeaderSubtitle"] = "Administra el catalogo de responsables de servicio de la plataforma.";

    ViewData["TableTitle"] = "Listado de responsables de servicio";
    ViewData["TableSubtitle"] = "Catalogo de responsables de servicio y sus descripciones.";
    ViewData["TableCount"] = 0;
    ViewData["TableCountLabel"] = "responsables";
    ViewData["TableExtraPill"] = "Catalogo Activo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-responsables-servicio.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <span class="eyebrow">Formulario</span>
            <h2 class="filter-title" id="formTitle">Registrar responsable de servicio</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripcion para registrar el responsable de servicio.</p>
        </div>
    </div>

    <form id="formResponsableServicio" class="filter-form-compact" novalidate onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombre">Nombre del responsable</label>
                <input id="strNombre" name="StrValor" class="form-control no-uppercase" placeholder="Ej. Juan Perez" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre del responsable ya existe.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcion">Descripcion (Opcional)</label>
                <textarea id="strDescripcion" name="StrDescripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Encargado del turno matutino" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripcion contiene caracteres no validos.</div>
            </div>
            <div class="col-md-12" id="statusContainer">
                <label class="form-label" for="intIdStatus">Estado del responsable</label>
                <select id="intIdStatus" name="IdCatStatus" class="form-select" required>
                    <option value="">-- Seleccionar Estado --</option>
                </select>
                <div class="invalid-feedback" id="statusFeedback">Selecciona un estatus.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar responsable</button>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />

    <div class="table-filter-bar d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="custom-tabs-container" id="statusTabs"></div>
        <div class="table-search-box position-relative">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar responsable..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre del responsable</th>
                    <th>Descripcion</th>
                    <th style="width: 120px;">Estado</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="responsablesTableBody"></tbody>
        </table>
    </div>

    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegacion de responsables de servicio">
            <ul class="pagination pagination-cavex m-0" id="paginationList"></ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vista-responsables-servicio.js" asp-append-version="true"></script>
}

