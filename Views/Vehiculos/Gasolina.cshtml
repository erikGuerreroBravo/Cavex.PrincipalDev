@{
    ViewData["Title"] = "Control de gasolina";
    ViewData["HeaderEyebrow"] = "Consumo vehicular";
    ViewData["HeaderTitle"] = "Control de gasolina";
    ViewData["HeaderSubtitle"] = "Registra cargas de combustible, costos, kilometraje, gasolinera y comprobantes por unidad.";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-vehiculos.css" asp-append-version="true" />
}

<!-- Header compartido del módulo Vehículos. -->
<partial name="_PageHeader" />

<!-- Formulario de VehControlGasolina.
     El cálculo de litros es exclusivamente visual y no agrega una columna al modelo SQL. -->
<form id="gasolinaVehiculoForm" class="vehiculo-create-form gasolina-vehiculo-form vehiculo-module-form">
    <div class="gasolina-form-grid">
        <div class="gasolina-main-column">
            <!-- Datos del vehículo: FK y kilometraje NOT NULL de VehControlGasolina. -->
            <section class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">1</span>Datos del vehículo</h3>
                <div class="row g-3">
                    <div class="col-lg-7">
                        <label class="form-label" for="gasolina-idVehDatosGenerales">Vehículo</label>
                        <select id="gasolina-idVehDatosGenerales" name="idVehDatosGenerales" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="gasolina-idVehDatosGeneralesError">Selecciona un vehículo.</div>
                    </div>
                    <div class="col-lg-5">
                        <label class="form-label" for="gasolina-decKilometrajeActual">Kilometraje al cargar</label>
                        <div class="input-group">
                            <input id="gasolina-decKilometrajeActual" name="decKilometrajeActual" type="number" min="0" max="999999" step="1" class="form-control" placeholder="0" required />
                            <span class="input-group-text">km</span>
                        </div>
                        <div class="invalid-feedback" id="gasolina-decKilometrajeActualError">Captura un kilometraje válido.</div>
                    </div>
                </div>

                <!-- Mini-card alimentada por la proyección simulada de VehDatosGenerales. -->
                <div id="gasolinaVehiculoCard" class="gasolina-vehiculo-card" hidden>
                    <div><span>Placa</span><strong id="gasolinaVehiculoPlaca">—</strong></div>
                    <div><span>Unidad</span><strong id="gasolinaVehiculoUnidad">—</strong></div>
                    <div><span>Año</span><strong id="gasolinaVehiculoAnio">—</strong></div>
                    <div><span>Kilometraje registrado</span><strong id="gasolinaVehiculoKilometraje">—</strong></div>
                </div>
            </section>

            <!-- Datos de carga y catálogos relacionados. -->
            <section class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">2</span>Datos de la carga</h3>
                <div class="row g-3">
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-dteFechaCarga">Fecha de carga</label>
                        <input id="gasolina-dteFechaCarga" name="dteFechaCarga" type="date" class="form-control" required />
                        <div class="invalid-feedback" id="gasolina-dteFechaCargaError">Captura una fecha válida.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-idVehCatGasolineras">Gasolinera</label>
                        <select id="gasolina-idVehCatGasolineras" name="idVehCatGasolineras" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="gasolina-idVehCatGasolinerasError">Selecciona una gasolinera.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-idEmpEmpleado">Empleado responsable</label>
                        <select id="gasolina-idEmpEmpleado" name="idEmpEmpleado" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="gasolina-idEmpEmpleadoError">Selecciona un empleado.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-mnyMontoPagado">Monto pagado</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="gasolina-mnyMontoPagado" name="mnyMontoPagado" type="number" min="0.01" max="999999" step="0.01" class="form-control" placeholder="0.00" required />
                        </div>
                        <div class="invalid-feedback" id="gasolina-mnyMontoPagadoError">Captura un monto mayor que cero.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-mnyPrecioLitro">Precio por litro</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input id="gasolina-mnyPrecioLitro" name="mnyPrecioLitro" type="number" min="0.01" max="99.99" step="0.01" class="form-control" placeholder="0.00" required />
                            <span class="input-group-text">/ L</span>
                        </div>
                        <div class="invalid-feedback" id="gasolina-mnyPrecioLitroError">Captura un precio entre $0.01 y $99.99.</div>
                    </div>
                    <div class="col-md-6 col-xl-4">
                        <label class="form-label" for="gasolina-idVehFormaPago">Forma de pago</label>
                        <select id="gasolina-idVehFormaPago" name="idVehFormaPago" class="form-select" required>
                            <option value="">Seleccionar...</option>
                        </select>
                        <div class="invalid-feedback" id="gasolina-idVehFormaPagoError">Selecciona una forma de pago.</div>
                    </div>
                </div>

                <!-- Cálculo informativo: no es campo ni columna de dbo.VehControlGasolina. -->
                <div class="gasolina-litros-card" aria-live="polite">
                    <div class="gasolina-litros-icon" aria-hidden="true">L</div>
                    <div>
                        <span>Litros estimados</span>
                        <strong id="gasolinaLitrosEstimados">0.00 L</strong>
                        <small>Monto pagado ÷ precio por litro. Dato únicamente visual.</small>
                    </div>
                </div>
            </section>

            <!-- Comprobante opcional: el backend futuro asignará la ruta a strUrlComprobantePago. -->
            <section class="cavex-card form-section-card vehiculo-section-card">
                <h3 class="form-section-title"><span class="form-section-number">3</span>Comprobante de pago</h3>
                <label class="form-label" for="gasolinaComprobanteArchivo">Archivo</label>
                <div id="gasolinaComprobanteArea" class="vehiculo-upload-area gasolina-comprobante-area" role="button" tabindex="0">
                    <input id="gasolinaComprobanteArchivo" type="file" class="vehiculo-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp" />
                    <input id="gasolina-strUrlComprobantePago" name="strUrlComprobantePago" type="hidden" value="" />
                    <div id="gasolinaComprobantePrompt" class="vehiculo-upload-prompt gasolina-comprobante-prompt">
                        <span class="vehiculo-upload-icon" aria-hidden="true">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                        </span>
                        <strong>Arrastra el comprobante aquí</strong>
                        <span>o haz clic para seleccionar</span>
                        <small>PDF, JPG, JPEG, PNG o WEBP · máximo 5 MB</small>
                    </div>
                    <div class="vehiculo-file-preview" id="gasolinaFilePreview" hidden>
                        <div class="vehiculo-file-meta">
                            <strong id="gasolinaFileName">Comprobante seleccionado</strong>
                            <small>Vista previa local; aún no se genera strUrlFoto</small>
                        </div>
                        <div class="vehiculo-file-actions gasolina-file-actions">
                            <button id="btnQuitarComprobanteGasolina" type="button" class="btn btn-outline-cavex btn-sm">Quitar</button>
                        </div>
                    </div>
                </div>
                <div id="gasolinaComprobanteArchivoError" class="invalid-feedback gasolina-upload-error"></div>
            </section>
        </div>

    </div>

    <!-- Acciones; Guardar solo valida mientras no exista POST /api/vehiculos/gasolina. -->
    <div class="form-action-bar vehiculo-action-bar">
        <a class="btn btn-outline-cavex" asp-controller="Vehiculos" asp-action="Index">Cancelar / Volver</a>
        <button type="submit" class="btn btn-cavex">Guardar carga</button>
    </div>
</form>

@section Scripts {
    <script src="~/js/vista-gasolina.js" asp-append-version="true"></script>
}
