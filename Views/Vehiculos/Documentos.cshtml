@{
    ViewData["Title"] = "Documentos del vehículo";
    ViewData["HeaderEyebrow"] = "Expediente vehicular";
    ViewData["HeaderTitle"] = "Documentos del vehículo";
    ViewData["HeaderSubtitle"] = "Controla factura, tarjeta de circulación, tenencia, verificación, seguro, permisos y placas.";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-vehiculos.css" asp-append-version="true" />
}

<!-- Header compartido del expediente; mantiene el contexto del módulo Vehículos. -->
<partial name="_PageHeader" />

<!-- Formulario multipanel del expediente documental.
     Solo el tab activo se valida y cada upload conserva el archivo localmente. -->
<form id="documentosVehiculoForm" class="documentos-vehiculo-form vehiculo-module-form" novalidate>
    <!-- Selector global: todos los documentos pertenecen a la misma FK idVehDatosGenerales. -->
    <section class="cavex-card form-section-card documentos-selector-card">
        <div class="row g-3 align-items-end">
            <div class="col-lg-6">
                <label class="form-label" for="documentos-idVehDatosGenerales">Vehículo</label>
                <select id="documentos-idVehDatosGenerales" name="idVehDatosGenerales" class="form-select" required>
                    <option value="">Seleccionar...</option>
                </select>
                <div class="invalid-feedback" id="documentos-idVehDatosGeneralesError">Selecciona un vehículo.</div>
            </div>
            <div class="col-lg-6">
                <!-- La mini-card se completa con la proyección simulada de VehDatosGenerales. -->
                <div id="documentosVehiculoCard" class="documentos-vehiculo-card" hidden>
                    <div><span>Placa</span><strong id="documentosVehiculoPlaca">—</strong></div>
                    <div><span>Marca</span><strong id="documentosVehiculoMarca">—</strong></div>
                    <div><span>Modelo</span><strong id="documentosVehiculoModelo">—</strong></div>
                    <div><span>Año</span><strong id="documentosVehiculoAnio">—</strong></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Resumen del expediente: los estados son simulados hasta disponer del GET real. -->
    <section aria-labelledby="documentosResumenTitulo">
        <div class="documentos-section-heading">
            <div>
                <span class="dashboard-kicker">Expediente</span>
                <h2 id="documentosResumenTitulo">Resumen documental</h2>
            </div>
            <small>Estado simulado por documento</small>
        </div>
        <div id="documentosResumenGrid" class="documentos-resumen-grid"></div>
    </section>

    <div class="documentos-workspace">
        <div class="documentos-main-column">
            <!-- Navegación por tabla detalle; solo el tab activo se valida al guardar. -->
            <nav class="documentos-tabs" aria-label="Tipos de documentos">
                <button type="button" class="documento-tab active" data-documento-tab="factura">Factura</button>
                <button type="button" class="documento-tab" data-documento-tab="tarjeta">Tarjeta de circulación</button>
                <button type="button" class="documento-tab" data-documento-tab="tenencia">Tenencia</button>
                <button type="button" class="documento-tab" data-documento-tab="verificacion">Verificación</button>
                <button type="button" class="documento-tab" data-documento-tab="seguro">Seguro</button>
                <button type="button" class="documento-tab" data-documento-tab="permiso">Permiso transporte</button>
                <button type="button" class="documento-tab" data-documento-tab="revista">Revista vehicular</button>
                <button type="button" class="documento-tab" data-documento-tab="contrato">Contrato arrendamiento</button>
                <button type="button" class="documento-tab" data-documento-tab="placas">Placas</button>
            </nav>

            <!-- Factura: VehDocumentosVehiculo.strUrlFactura. -->
            <section class="cavex-card form-section-card documento-panel active" data-documento-panel="factura" data-documento-label="Factura">
                <h3 class="form-section-title">Factura</h3>
                <p class="documento-panel-description">Archivo principal asociado a <code>VehDocumentosVehiculo.strUrlFactura</code>.</p>
                <div class="documento-upload" data-documento-upload data-required-upload="true" data-url-id="factura-strUrlFactura" tabindex="0" role="button">
                    <input type="file" id="facturaArchivo" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp" />
                    <input type="hidden" id="factura-strUrlFactura" name="strUrlFactura" />
                    <div class="documento-upload-prompt">
                        <strong>Arrastra la factura aquí</strong>
                        <span>PDF o imagen · máximo 5 MB</span>
                    </div>
                    <div class="documento-upload-file" hidden>
                        <div><span class="documento-file-type">Archivo</span><strong class="documento-file-name">Sin archivo</strong></div>
                        <button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button>
                    </div>
                </div>
                <div class="invalid-feedback documento-upload-error"></div>
            </section>

            <!-- Tarjeta de circulación: campos de dbo.VehTarjetaCirculacion. -->
            <section class="cavex-card form-section-card documento-panel" data-documento-panel="tarjeta" data-documento-label="Tarjeta de circulación" hidden>
                <h3 class="form-section-title">Tarjeta de circulación</h3>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label" for="tarjeta-strNumeroTarjeta">Número de tarjeta</label><input id="tarjeta-strNumeroTarjeta" name="strNumeroTarjeta" maxlength="50" class="form-control" required /><div class="invalid-feedback" id="tarjeta-strNumeroTarjetaError"></div></div>
                    <div class="col-md-6"><label class="form-label" for="tarjeta-idEmpCatEntidadFederativa">Entidad federativa</label><select id="tarjeta-idEmpCatEntidadFederativa" name="idEmpCatEntidadFederativa" class="form-select documento-catalogo" data-catalogo="entidades" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="tarjeta-idEmpCatEntidadFederativaError"></div></div>
                    <div class="col-md-6"><label class="form-label" for="tarjeta-dteFechaExpedicion">Fecha de expedición</label><input id="tarjeta-dteFechaExpedicion" name="dteFechaExpedicion" type="date" class="form-control" data-fecha-inicio required /><div class="invalid-feedback" id="tarjeta-dteFechaExpedicionError"></div></div>
                    <div class="col-md-6"><label class="form-label" for="tarjeta-dteFechaVencimiento">Fecha de vencimiento</label><input id="tarjeta-dteFechaVencimiento" name="dteFechaVencimiento" type="date" class="form-control" data-fecha-fin required /><div class="invalid-feedback" id="tarjeta-dteFechaVencimientoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tarjeta-idVehCatStatus">Estatus</label><select id="tarjeta-idVehCatStatus" name="idVehCatStatus" class="form-select documento-catalogo" data-catalogo="status" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="tarjeta-idVehCatStatusError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tarjeta-mnyMontoPagado">Monto pagado</label><input id="tarjeta-mnyMontoPagado" name="mnyMontoPagado" type="number" min="0" max="999999" step="0.01" class="form-control" required /><div class="invalid-feedback" id="tarjeta-mnyMontoPagadoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tarjeta-idVehFormaPago">Forma de pago</label><select id="tarjeta-idVehFormaPago" name="idVehFormaPago" class="form-select documento-catalogo" data-catalogo="formasPago" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="tarjeta-idVehFormaPagoError"></div></div>
                </div>
                <div class="documentos-upload-grid">
                    <div><label class="form-label">Comprobante de pago</label><div class="documento-upload" data-documento-upload data-url-id="tarjeta-strUrlComprobantePago" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="tarjeta-strUrlComprobantePago" name="strUrlComprobantePago" /><div class="documento-upload-prompt"><strong>Seleccionar comprobante</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                    <div><label class="form-label">Tarjeta digital</label><div class="documento-upload" data-documento-upload data-url-id="tarjeta-strUrlTarjeta" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="tarjeta-strUrlTarjeta" name="strUrlTarjeta" /><div class="documento-upload-prompt"><strong>Seleccionar tarjeta</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                </div>
            </section>

            <!-- Tenencia: campos de dbo.VehTenencia. -->
            <section class="cavex-card form-section-card documento-panel" data-documento-panel="tenencia" data-documento-label="Tenencia" hidden>
                <h3 class="form-section-title">Tenencia</h3>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label" for="tenencia-intAnio">Año</label><input id="tenencia-intAnio" name="intAnio" type="number" min="1990" step="1" class="form-control documento-anio" required /><div class="invalid-feedback" id="tenencia-intAnioError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-dteFechaPago">Fecha de pago</label><input id="tenencia-dteFechaPago" name="dteFechaPago" type="date" class="form-control" data-fecha-inicio required /><div class="invalid-feedback" id="tenencia-dteFechaPagoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-dteFechaVencimiento">Fecha de vencimiento</label><input id="tenencia-dteFechaVencimiento" name="dteFechaVencimiento" type="date" class="form-control" data-fecha-fin required /><div class="invalid-feedback" id="tenencia-dteFechaVencimientoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-mnyMontoPagado">Monto pagado</label><input id="tenencia-mnyMontoPagado" name="mnyMontoPagado" type="number" min="0" max="999999" step="0.01" class="form-control" required /><div class="invalid-feedback" id="tenencia-mnyMontoPagadoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-strFolioPago">Folio de pago</label><input id="tenencia-strFolioPago" name="strFolioPago" maxlength="50" class="form-control" required /><div class="invalid-feedback" id="tenencia-strFolioPagoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-idVehCatFormaPago">Forma de pago</label><select id="tenencia-idVehCatFormaPago" name="idVehCatFormaPago" class="form-select documento-catalogo" data-catalogo="formasPago" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="tenencia-idVehCatFormaPagoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="tenencia-idVehCatStatus">Estatus</label><select id="tenencia-idVehCatStatus" name="idVehCatStatus" class="form-select documento-catalogo" data-catalogo="status" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="tenencia-idVehCatStatusError"></div></div>
                </div>
                <div class="documentos-upload-grid">
                    <div><label class="form-label">Comprobante</label><div class="documento-upload" data-documento-upload data-url-id="tenencia-strUrlComprobantePago" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="tenencia-strUrlComprobantePago" name="strUrlComprobantePago" /><div class="documento-upload-prompt"><strong>Seleccionar comprobante</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                    <div><label class="form-label">Formato de tenencia</label><div class="documento-upload" data-documento-upload data-url-id="tenencia-strUrlFormatoTenencia" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="tenencia-strUrlFormatoTenencia" name="strUrlFormatoTenencia" /><div class="documento-upload-prompt"><strong>Seleccionar formato</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                </div>
            </section>

            <!-- Verificación: campos de dbo.VehVerificacion. -->
            <section class="cavex-card form-section-card documento-panel" data-documento-panel="verificacion" data-documento-label="Verificación" hidden>
                <h3 class="form-section-title">Verificación</h3>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label" for="verificacion-strFolioVerificacion">Folio</label><input id="verificacion-strFolioVerificacion" name="strFolioVerificacion" maxlength="50" class="form-control" required /><div class="invalid-feedback" id="verificacion-strFolioVerificacionError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="verificacion-idVehCatHolograma">Holograma</label><select id="verificacion-idVehCatHolograma" name="idVehCatHolograma" class="form-select documento-catalogo" data-catalogo="hologramas" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="verificacion-idVehCatHologramaError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="verificacion-strCentroVerificacion">Centro de verificación</label><input id="verificacion-strCentroVerificacion" name="strCentroVerificacion" maxlength="300" class="form-control" required /><div class="invalid-feedback" id="verificacion-strCentroVerificacionError"></div></div>
                    <div class="col-md-3"><label class="form-label" for="verificacion-intAnio">Año</label><input id="verificacion-intAnio" name="intAnio" type="number" min="1990" step="1" class="form-control documento-anio" required /><div class="invalid-feedback" id="verificacion-intAnioError"></div></div>
                    <div class="col-md-3"><label class="form-label" for="verificacion-strSemestre">Semestre</label><select id="verificacion-strSemestre" name="strSemestre" class="form-select" required><option value="">Seleccionar...</option><option value="Primer semestre">Primer semestre</option><option value="Segundo semestre">Segundo semestre</option></select><div class="invalid-feedback" id="verificacion-strSemestreError"></div></div>
                    <div class="col-md-3"><label class="form-label" for="verificacion-dteFechaVerificacion">Fecha de verificación</label><input id="verificacion-dteFechaVerificacion" name="dteFechaVerificacion" type="date" class="form-control" data-fecha-inicio required /><div class="invalid-feedback" id="verificacion-dteFechaVerificacionError"></div></div>
                    <div class="col-md-3"><label class="form-label" for="verificacion-dteFechaVencimiento">Fecha de vencimiento</label><input id="verificacion-dteFechaVencimiento" name="dteFechaVencimiento" type="date" class="form-control" data-fecha-fin required /><div class="invalid-feedback" id="verificacion-dteFechaVencimientoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="verificacion-idVehCatStatus">Estatus</label><select id="verificacion-idVehCatStatus" name="idVehCatStatus" class="form-select documento-catalogo" data-catalogo="status" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="verificacion-idVehCatStatusError"></div></div>
                </div>
            </section>

            <!-- Seguro: campos de dbo.VehSeguro; se conserva el nombre SQL mnyMontoCoberura. -->
            <section class="cavex-card form-section-card documento-panel" data-documento-panel="seguro" data-documento-label="Seguro" hidden>
                <h3 class="form-section-title">Seguro</h3>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label" for="seguro-idVehCatAseguradora">Aseguradora</label><select id="seguro-idVehCatAseguradora" name="idVehCatAseguradora" class="form-select documento-catalogo" data-catalogo="aseguradoras" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="seguro-idVehCatAseguradoraError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-strNumeroPoliza">Número de póliza</label><input id="seguro-strNumeroPoliza" name="strNumeroPoliza" maxlength="100" class="form-control" required /><div class="invalid-feedback" id="seguro-strNumeroPolizaError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-idVehCatTipoCobertura">Tipo de cobertura</label><select id="seguro-idVehCatTipoCobertura" name="idVehCatTipoCobertura" class="form-select documento-catalogo" data-catalogo="coberturas" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="seguro-idVehCatTipoCoberturaError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-mnyMontoCoberura">Monto de cobertura</label><input id="seguro-mnyMontoCoberura" name="mnyMontoCoberura" type="number" min="0" max="999999" step="0.01" class="form-control" required /><div class="invalid-feedback" id="seguro-mnyMontoCoberuraError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-mnyMontoPagado">Monto pagado</label><input id="seguro-mnyMontoPagado" name="mnyMontoPagado" type="number" min="0" max="999999" step="0.01" class="form-control" required /><div class="invalid-feedback" id="seguro-mnyMontoPagadoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-idVehFormaPago">Forma de pago</label><select id="seguro-idVehFormaPago" name="idVehFormaPago" class="form-select documento-catalogo" data-catalogo="formasPago" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="seguro-idVehFormaPagoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-dteFechaInicio">Fecha de inicio</label><input id="seguro-dteFechaInicio" name="dteFechaInicio" type="date" class="form-control" data-fecha-inicio required /><div class="invalid-feedback" id="seguro-dteFechaInicioError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-dteFechaVencimiento">Fecha de vencimiento</label><input id="seguro-dteFechaVencimiento" name="dteFechaVencimiento" type="date" class="form-control" data-fecha-fin required /><div class="invalid-feedback" id="seguro-dteFechaVencimientoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="seguro-idVehCatStatus">Estatus</label><select id="seguro-idVehCatStatus" name="idVehCatStatus" class="form-select documento-catalogo" data-catalogo="status" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="seguro-idVehCatStatusError"></div></div>
                </div>
                <div class="documentos-upload-grid">
                    <div><label class="form-label">Comprobante</label><div class="documento-upload" data-documento-upload data-url-id="seguro-strUrlComprobantePago" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="seguro-strUrlComprobantePago" name="strUrlComprobantePago" /><div class="documento-upload-prompt"><strong>Seleccionar comprobante</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                    <div><label class="form-label">Póliza digital</label><div class="documento-upload" data-documento-upload data-url-id="seguro-strUrlPolizaSeguro" tabindex="0" role="button"><input type="file" class="documento-file-input" accept=".pdf,.jpg,.jpeg,.png,.webp" /><input type="hidden" id="seguro-strUrlPolizaSeguro" name="strUrlPolizaSeguro" /><div class="documento-upload-prompt"><strong>Seleccionar póliza</strong><span>PDF o imagen · 5 MB</span></div><div class="documento-upload-file" hidden><div><span class="documento-file-type">Archivo</span><strong class="documento-file-name"></strong></div><button type="button" class="btn btn-outline-cavex btn-sm documento-remove-file">Quitar</button></div></div><div class="invalid-feedback documento-upload-error"></div></div>
                </div>
            </section>

            <!-- Permiso de transporte: campos de dbo.VehPermisoTransporte. -->
            <section class="cavex-card form-section-card documento-panel" data-documento-panel="permiso" data-documento-label="Permiso de transporte" hidden>
                <h3 class="form-section-title">Permiso de transporte</h3>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label" for="permiso-strNumeroPermiso">Número de permiso</label><input id="permiso-strNumeroPermiso" name="strNumeroPermiso" maxlength="50" class="form-control" required /><div class="invalid-feedback" id="permiso-strNumeroPermisoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="permiso-idVehCatTipoPermiso">Tipo de permiso</label><select id="permiso-idVehCatTipoPermiso" name="idVehCatTipoPermiso" class="form-select documento-catalogo" data-catalogo="tiposPermiso" required><option value="">Seleccionar...</option></select><div class="invalid-feedback" id="permiso-idVehCatTipoPermisoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="permiso-strAutoridad">Autoridad</label><input id="permiso-strAutoridad" name="strAutoridad" maxlength="300" class="form-control" required /><div class="invalid-feedback" id="permiso-strAutoridadError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="permiso-dteFechaExpedicion">Fecha de expedición</label><input id="permiso-dteFechaExpedicion" name="dteFechaExpedicion" type="date" class="form-control" data-fecha-inicio required /><div class="invalid-feedback" id="permiso-dteFechaExpedicionError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="permiso-dteFechaVencimiento">Fecha de vencimiento</label><input id="permiso-dteFechaVencimiento" name="dteFechaVencimiento" type="date" class="form-control" data-fecha-fin required /><div class="invalid-feedback" id="permiso-dteFechaVencimientoError"></div></div>
                    <div class="col-md-4"><label class="form-label" for="permiso-mnyMontoPagado">Monto pagado</label><input id="permiso-mnyMontoPagado" name="mnyMontoPagado" type="number" min="0" max="999999" step="0.01" class="form-control" required /><div class="invalid-feedback" id="permiso-mnyMontoPagadoError"></div></div>
