@{
    ViewData["Title"] = "Nuevos Parámetros";
}

<partial name="_PageHeader"  />

<form action="#" class="quote-form">
    <div class="cavex-card form-section-card">
        <h3 class="form-section-title">Variables operativas base</h3>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Inicio de vigencia</label>
                <input name="FechaInicioVigencia" id="strFechaInicioVigencia" type="date" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Gasolina (MXN/L)</label>
                <input name="PrecioGasolinaLitro" id="intPrecioGasolinaLitro" type="number" step="0.01" min="0" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Rendimiento (km/L)</label>
                <input name="RendimientoKmLitro" id="intRendimientoKmLitro" type="number" step="0.01" min="0.1" class="form-control" required />
            </div>
        </div>
    </div>
    
    <div class="cavex-card form-section-card">
        <h3 class="form-section-title">Costos por kilómetro</h3>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Mantenimiento (MXN/km)</label>
                <input name="MantenimientoKm" id="intMantenimientoKm" type="number" step="0.0001" min="0" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Depreciación (MXN/km)</label>
                <input name="DepreciacionKm" id="intDepreciacionKm" type="number" step="0.0001" min="0" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Seguro (MXN/km)</label>
                <input name="SeguroKm" id="intSeguroKm" type="number" step="0.0001" min="0" class="form-control" required />
            </div>
        </div>
    </div>

    <div class="cavex-card form-section-card">
        <h3 class="form-section-title">Tarifas y márgenes comerciales</h3>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Tarifa base asistencia (MXN)</label>
                <input name="TarifaAsistencia" id="intTarifaAsistencia" type="number" step="0.01" min="0" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Margen de utilidad (%)</label>
                <input name="Margen" id="intMargen" type="number" step="0.01" min="0" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">IVA (%)</label>
                <input name="IVA" id="intIVA" type="number" step="0.01" min="0" class="form-control" required />
            </div>
        </div>
    </div>
    
    <div class="cavex-card form-section-card">
        <h3 class="form-section-title">Configuración</h3>
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-check catalog-check">
                    <input name="Activo" id="strActivo" type="checkbox" class="form-check-input" value="true" checked />
                    <span class="form-check-label">Establecer como configuración activa (desactivará las anteriores)</span>
                </label>
            </div>
        </div>
    </div>
    
    <div class="form-action-bar mt-4">
        <a class="btn btn-outline-cavex" asp-controller="ParametrosCosto" asp-action="Index">Cancelar</a>
        <button type="submit" class="btn btn-cavex">Guardar parámetros</button>
    </div>
</form>



