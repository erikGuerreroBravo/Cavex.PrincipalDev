
@{
    ViewData["Title"] = "Editar sucursal";
}

<div class="page-hero">
    <div>
        <span class="eyebrow">Red operativa</span>
        <h1 class="cavex-title">Editar sucursal</h1>
        <p class="cavex-subtitle">Actualiza una oficina sin afectar cotizaciones histÃ³ricas.</p>
    </div>
    <a class="btn btn-outline-cavex" asp-controller="Sucursales" asp-action="Index">Volver</a>
</div>

<form method="post" asp-controller="Sucursales" asp-action="Edit" asp-route-id="1">
    <input name="Id" id="Id" type="hidden" />
    <div class="cavex-card address-card">
        <h3 class="form-section-title"><span class="form-section-number">1</span>Datos y coordenadas</h3>
        <div  class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label name="Nombre" id="Nombre" class="form-label">Nombre</label>
                <input name="Nombre" id="Nombre" class="form-control" required />
                
            </div>
            <div class="col-md-6">
                <label name="Telefono" id="Telefono" class="form-label">TelÃ©fono</label>
                <input name="Telefono" id="Telefono" class="form-control" />
            </div>
            <div class="col-md-12">
                <label name="Direccion" id="Direccion" class="form-label">DirecciÃ³n</label>
                <input name="Direccion" id="Direccion" class="form-control" required />
                
            </div>
            <div class="col-md-4">
                <label name="Municipio" id="Municipio" class="form-label">Municipio</label>
                <input name="Municipio" id="Municipio" class="form-control" required />
                
            </div>
            <div class="col-md-4">
                <label name="Estado" id="Estado" class="form-label">Estado</label>
                <input name="Estado" id="Estado" class="form-control" required />
                
            </div>
            <div class="col-md-4">
                <label name="CodigoPostal" id="CodigoPostal" class="form-label">CÃ³digo postal</label>
                <input name="CodigoPostal" id="CodigoPostal" class="form-control" />
            </div>
            <div class="col-md-4">
                <label name="Latitud" id="Latitud" class="form-label">Latitud</label>
                <input name="Latitud" id="Latitud" type="number" step="0.000001" class="form-control" />
            </div>
            <div class="col-md-4">
                <label name="Longitud" id="Longitud" class="form-label">Longitud</label>
                <input name="Longitud" id="Longitud" type="number" step="0.000001" class="form-control" />
            </div>
            <div class="col-md-8">
                <small class="form-help">Las coordenadas se usan para calcular la distancia desde la sucursal hasta el destino del cliente.</small>
            </div>
            <div class="col-md-4">
                <label class="form-check catalog-check mt-4">
                    <input name="Activa" id="Activa" class="form-check-input" />
                    <span class="form-check-label">Activa</span>
                </label>
            </div>
        </div>
    </div>
    <div class="form-action-bar">
        <button type="submit" class="btn btn-cavex">Guardar cambios</button>
        <a class="btn btn-outline-cavex" asp-controller="Sucursales" asp-action="Index">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}




