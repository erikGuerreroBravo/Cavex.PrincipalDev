
@{
    ViewData["Title"] = "Sucursales";
}

<partial name="_PageHeader"  />

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />
    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Dirección</th>
                    <th>Municipio</th>
                    <th>Estado</th>
                    <th>Coordenadas</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                                <tr>
                    <td><span class="cotizacion-main-text">Base Centro</span></td>
                    <td><div class="text-clamp-2">Av. Insurgentes 123, Col. Roma</div></td>
                    <td>Cuauhtémoc</td>
                    <td>CDMX</td>
                    <td>
                        <span class="badge-info">Coordenadas</span>
                        <div class="text-muted small">19.428470, -99.127660</div>
                    </td>
                    <td><partial name="_StatusBadge" model='@("Activa")' /></td>
                    <td class="text-end">
                        <div class="dropdown actions-dropdown">
                            <button class="btn btn-outline-cavex btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">Acciones</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#">Editar</a></li>
                                <li>
                                    <form method="post" action="#">
                                        <button type="submit" class="dropdown-item">Desactivar</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><span class="cotizacion-main-text">Base Sur</span></td>
                    <td><div class="text-clamp-2">Anillo Periférico 456, Jardines del Pedregal</div></td>
                    <td>Coyoacán</td>
                    <td>CDMX</td>
                    <td>
                        <span class="badge-info">Coordenadas</span>
                        <div class="text-muted small">19.304130, -99.189740</div>
                    </td>
                    <td><partial name="_StatusBadge" model='@("Activa")' /></td>
                    <td class="text-end">
                        <div class="dropdown actions-dropdown">
                            <button class="btn btn-outline-cavex btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">Acciones</button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#">Editar</a></li>
                                <li>
                                    <form method="post" action="#">
                                        <button type="submit" class="dropdown-item">Desactivar</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>





