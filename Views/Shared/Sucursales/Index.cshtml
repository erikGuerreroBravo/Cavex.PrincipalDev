@model Cavex.Principal.Models.CatSucursal.CatSucursalSaveDto;
@{
    ViewData["Title"] = "Nueva Sucursal";
    ViewData["HeaderEyebrow"] = "Configuración";
    ViewData["HeaderTitle"] = "Nueva Sucursal";
    ViewData["HeaderSubtitle"] = "Administra el catálogo de sucursales de la plataforma.";

    ViewData["TableTitle"] = "Listado de sucursales";
    ViewData["TableSubtitle"] = "Catálogo de sucursales de traslado y sus descripciones.";
    ViewData["TableCount"] = 0;
    ViewData["TableCountLabel"] = "sucursales";
    ViewData["TableExtraPill"] = "Catálogo Activo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-servicios.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="filter-title" id="formTitle">Registrar sucursal</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripción para registrar la sucursal.</p>
        </div>
    </div>

    <form id="formSucursal" class="filter-form-compact" novalidate onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombreSucursal">Nombre de la sucursal</label>
                <input id="strNombreSucursal" name="strValor" class="form-control no-uppercase" placeholder="Ej. Sucursal Matriz" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre de la sucursal ya existe.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcionSucursal">Dirección / Descripción (Opcional)</label>
                <textarea id="strDescripcionSucursal" name="Descripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Av. Juárez #456, Col. Del Valle" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripción contiene caracteres no válidos.</div>
            </div>
                <div class="col-md-12" id="statusContainer">
                <label class="form-label" for="intIdStatusSucursal">Estado de la sucursal</label>
                <select id="intIdStatusSucursal" name="IdCatStatus" class="form-select">
                    <option value="">-- Seleccionar Estado --</option>
                    <option value="1">Activo</option>
                    <option value="2002">Dar de Baja</option>
                </select>
                <div class="invalid-feedback" id="statusFeedback">El estado seleccionado no es válido.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar sucursal</button>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />
    
    <!-- Barra de Búsqueda y Pestañas de Estado -->
    <div class="table-filter-bar d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="custom-tabs-container">
            <button type="button" class="tab-item active" onclick="setStatusFilter('todos')" id="tabTodos">
                Todos <span class="tab-count count-all" id="countTodos">0</span>
            </button>
            <button type="button" class="tab-item" onclick="setStatusFilter('activos')" id="tabActivos">
                Activos <span class="tab-count count-active" id="countActivos">0</span>
            </button>
            <button type="button" class="tab-item" onclick="setStatusFilter('baja')" id="tabBaja">
                Baja <span class="tab-count count-inactive" id="countBaja">0</span>
            </button>
        </div>
        <div class="table-search-box position-relative">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar sucursal..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre de la sucursal</th>
                    <th>Ubicación / Descripción</th>
                    <th style="width: 120px;">Estado</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="sucursalesTableBody">
                <!-- Generado dinámicamente por JavaScript -->
            </tbody>
        </table>
    </div>

    <!-- Barra de Paginación -->
    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegación de sucursales">
            <ul class="pagination pagination-cavex m-0" id="paginationList">
                <!-- Generado dinámicamente -->
            </ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vista-sucursales.js" asp-append-version="true"></script>
}
