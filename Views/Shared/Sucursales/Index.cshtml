@model Cavex.Principal.Models.CatSucursal.CatSucursalSaveDto
@{
    ViewBag.Title = "Nueva Sucursal";
    ViewBag.HeaderEyebrow = "Configuracion";
    ViewBag.HeaderTitle = "Nueva Sucursal";
    ViewBag.HeaderSubtitle = "Administra el catalogo de sucursales de la plataforma.";

    ViewBag.TableTitle = "Listado de sucursales";
    ViewBag.TableSubtitle = "Catalogo de sucursales de traslado y sus descripciones.";
    ViewBag.TableCount = 0;
    ViewBag.TableCountLabel = "sucursales";
    ViewBag.TableExtraPill = "Catalogo Activo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-servicios.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="filter-title" id="formTitle">Registrar sucursal</h2>
            <p class="cavex-subtitle" id="formSubtitle">Ingresa el nombre y la descripcion para registrar la sucursal.</p>
        </div>
    </div>

    <form id="formSucursal" class="filter-form-compact" onsubmit="handleFormSubmit(event)">
        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label" for="strNombreSucursal">Nombre de la sucursal</label>
                <input id="strNombreSucursal" name="StrValor" class="form-control no-uppercase" placeholder="Ej. Sucursal Matriz" required />
                <div class="invalid-feedback" id="nombreFeedback">El nombre de la sucursal ya existe.</div>
            </div>
            <div class="col-md-12">
                <label class="form-label" for="strDescripcionSucursal">Direccion / Descripcion (Opcional)</label>
                <textarea id="strDescripcionSucursal" name="StrDescripcion" class="form-control no-uppercase" rows="3" placeholder="Ej. Av. Juarez #456, Col. Del Valle" style="resize: none;"></textarea>
                <div class="invalid-feedback" id="descripcionFeedback">La descripcion contiene caracteres no validos.</div>
            </div>
            <div class="col-md-12" id="statusContainer">
                <label class="form-label" for="intIdStatusSucursal">Estado de la sucursal</label>
                <select id="intIdStatusSucursal" name="IdCatStatus" class="form-select" required>
                    <option value="">-- Seleccionar Estado --</option>
                </select>
                <div class="invalid-feedback" id="statusFeedback">Selecciona un estatus.</div>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex" id="btnSubmit">Guardar sucursal</button>
            <button type="button" class="btn btn-outline-cavex" id="btnCancel" onclick="resetForm()" style="display: none;">Cancelar</button>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader" />

    <div class="table-filter-bar d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div class="custom-tabs-container" id="statusTabs"></div>
        <div class="table-search-box position-relative">
            <input type="text" id="tableSearch" class="form-control" placeholder="Buscar sucursal..." oninput="handleSearch(this.value)" />
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact">
            <thead>
                <tr>
                    <th>Nombre de la sucursal</th>
                    <th>Ubicacion / Descripcion</th>
                    <th style="width: 120px;">Estado</th>
                    <th class="text-end" style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="sucursalesTableBody"></tbody>
        </table>
    </div>

    <div class="table-footer-bar">
        <div class="pagination-info small" id="paginationInfo">
            Mostrando 0-0 de 0 registros
        </div>
        <nav aria-label="Navegacion de sucursales">
            <ul class="pagination pagination-cavex m-0" id="paginationList"></ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/vista-sucursales.js" asp-append-version="true"></script>
}
