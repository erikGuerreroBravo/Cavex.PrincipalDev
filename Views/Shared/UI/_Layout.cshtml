<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Grupo CAVEX</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/layout-principal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/componentes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/formularios.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsivo.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    @await RenderSectionAsync("Head", required: false)
</head>

<body>
    <header class="cavex-navbar">
        <div class="container-fluid d-flex flex-wrap justify-content-between align-items-center gap-3">
            <a class="cavex-brand" asp-controller="Home" asp-action="Index">
                <img class="cavex-brand-logo" src="~/img/logocavex.jpeg" />
            </a>

            <nav class="cavex-nav">
                <a asp-controller="Home" asp-action="Index">
                    <svg class="btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Panel interno
                </a>

                <a asp-controller="Vehiculos" asp-action="Index">
                    <svg class="btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 1 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
                    Vehículos
                </a>

                <div class="nav-dropdown">
                    <button class="nav-dropdown-btn">
                        <svg class="btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                        Operaciones 
                        <span class="dropdown-arrow">▾</span>
                    </button>
                    <div class="nav-dropdown-menu">
                        <a asp-controller="Cotizaciones" asp-action="Index" class="mega-menu-item">
                            <div class="item-icon-box item-icon-cyan">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Cotizaciones</span>
                                <span class="item-desc">Listado e historial de solicitudes guardadas.</span>
                            </div>
                        </a>
                        <a asp-controller="Cotizaciones" asp-action="Create" class="mega-menu-item">
                            <div class="item-icon-box item-icon-teal">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2-2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Nueva cotización</span>
                                <span class="item-desc">Cotizador dinámico con mapa y cálculo de tarifas.</span>
                            </div>
                        </a>

                    </div>
                </div>

                <div class="nav-dropdown">
                    <button class="nav-dropdown-btn">
                        <svg class="btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        Administración 
                        <span class="dropdown-arrow">▾</span>
                    </button>
                    <div class="nav-dropdown-menu">
                        <a asp-controller="Sucursales" asp-action="Index" class="mega-menu-item">
                            <div class="item-icon-box item-icon-blue">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Nueva Sucursal</span>
                                <span class="item-desc">Gestión de bases y sedes de origen.</span>
                            </div>
                        </a>
                        <a asp-controller="Servicios" asp-action="Index" class="mega-menu-item">
                            <div class="item-icon-box item-icon-orange">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Nuevo Servicio</span>
                                <span class="item-desc">Alta de nuevos servicios.</span>
                            </div>
                        </a>
                        <a asp-controller="Empleado" asp-action="Create" class="mega-menu-item">
                            <div class="item-icon-box item-icon-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Nuevo Empleado</span>
                                <span class="item-desc">Alta de empleados y configuración de roles.</span>
                            </div>
                        </a>
                        <a asp-controller="Empleado" asp-action="Index" class="mega-menu-item">
                            <div class="item-icon-box item-icon-blue">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Lista de Empleados</span>
                                <span class="item-desc">Consulta de empleados registrados y su estado.</span>
                            </div>
                        </a>
                        <a asp-controller="EmpCatAreaLaboral" asp-action="Index" class="mega-menu-item">
                            <div class="item-icon-box item-icon-purple">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Áreas Laborales</span>
                                <span class="item-desc">Gestión de departamentos interno.</span>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="nav-dropdown profile-dropdown">
                    <button class="nav-profile-circle" title="Usuario Demo">
                        <span>UD</span>
                    </button>
                    <div class="nav-dropdown-menu dropdown-right">
                        <div class="profile-info">
                            <strong>Usuario Demo</strong>
                            <small>Administrador</small>
                        </div>
                        <hr class="dropdown-divider">
                        <a href="#" class="mega-menu-item profile-action-item">
                            <div class="item-icon-box item-icon-gray">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                            <div class="item-details">
                                <span class="item-title">Mi Perfil</span>
                            </div>
                        </a>
                        <form method="post" asp-controller="Auth" asp-action="Logout" class="m-0">
                            <button type="submit" class="nav-logout-btn">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                Cerrar sesión
                            </button>
                        </form>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <main class="cavex-container">
        @RenderBody()
    </main>

    <footer class="cavex-footer">
        <small>&copy; 2026 - Grupo CAVEX | Cotizador interno de traslados seguros</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
