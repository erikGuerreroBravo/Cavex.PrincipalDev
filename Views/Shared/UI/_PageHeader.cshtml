@{
    var containerClass = ViewData["HeaderContainerClass"] as string ?? "internal-header";
    var eyebrow = ViewData["HeaderEyebrow"] as string;
    var title = ViewData["HeaderTitle"] as string ?? ViewData["Title"] as string;
    var subtitle = ViewData["HeaderSubtitle"] as string;
    var buttonText = ViewData["HeaderButtonText"] as string;
    var buttonAction = ViewData["HeaderButtonAction"] as string;
    var buttonController = ViewData["HeaderButtonController"] as string;
    var buttonClass = ViewData["HeaderButtonClass"] as string ?? "btn btn-cavex";
    var badgeText = ViewData["HeaderBadgeText"] as string;
    var badgeClass = ViewData["HeaderBadgeClass"] as string ?? "badge-cavex";
}
<div class="@containerClass">
    <div>
        @if (!string.IsNullOrWhiteSpace(eyebrow))
        {
            <span class="eyebrow">@eyebrow</span>
        }
        <h1 class="cavex-title">@title</h1>
        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <p class="cavex-subtitle">@subtitle</p>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(buttonText) && !string.IsNullOrWhiteSpace(buttonAction))
    {
        <a class="@buttonClass" asp-controller="@buttonController" asp-action="@buttonAction">@buttonText</a>
    }
    else if (!string.IsNullOrWhiteSpace(badgeText))
    {
        <span class="@badgeClass">@badgeText</span>
    }
</div>
