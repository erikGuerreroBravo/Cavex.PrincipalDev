<div class="cavex-card form-section-card">
    <h3 class="form-section-title"><span class="form-section-number">6</span>Costos adicionales</h3>
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Peajes</label>
            <input name="Peajes" id="intPeajes" type="number" step="0.01" min="0" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Estacionamiento</label>
            <input name="Estacionamiento" id="intEstacionamiento" type="number" step="0.01" min="0" class="form-control" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Observaciones generales</label>
            <textarea name="Observaciones" id="strObservaciones" class="form-control" rows="3"></textarea>
        </div>
    </div>
</div>
