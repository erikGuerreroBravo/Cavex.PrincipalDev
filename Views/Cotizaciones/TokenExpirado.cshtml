@{
    ViewData["Title"] = "Enlace expirado";
}

<div class="quote-sheet">
    <div class="quote-header">
        <div>
            <div class="quote-logo-wrap">
                <img class="cavex-logo-img" src="~/img/logocavex.jpeg" onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
                <div class="quote-logo d-none">Grupo <span>CAVEX</span></div>
            </div>
            <p class="text-muted mb-0">Tu destino, nuestra prioridad</p>
        </div>
        <div class="quote-meta">
            <strong>CAVEX-2024-000001</strong>
        </div>
    </div>

    <div class="alert alert-warning mt-4 mb-0">
        <strong>Este enlace público expiró.</strong>
        <div>Solicita a Grupo CAVEX una cotización actualizada o un nuevo enlace seguro.</div>
    </div>

    <div class="quote-contact-box mt-4">
        <strong>Contacto Grupo CAVEX</strong>
        <div>WhatsApp: 773 150 6305</div>
        <div>Correo: grupocavex18@gmail.com</div>
    </div>
</div>


