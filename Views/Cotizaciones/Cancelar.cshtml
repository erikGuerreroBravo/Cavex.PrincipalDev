@{
    ViewData["Title"] = "Cancelar cotización";
}

<partial name="_PageHeader"  />

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <form action="#" class="quote-form">
            <div class="cavex-card cancel-form-card">
                <span class="dashboard-kicker">Confirmación requerida</span>
                <h3 class="form-section-title mb-2">Motivo de cancelación</h3>
                <p class="form-help mb-3">Describe el motivo para dejar trazabilidad operativa en el historial interno.</p>
                <label for="strMotivoCancelacion" class="form-label">Motivo de cancelación</label>
                <textarea id="strMotivoCancelacion" name="motivoCancelacion" class="form-control" rows="5" required placeholder="Describe por qué se cancela esta cotización"></textarea>
            </div>
            <div class="d-flex flex-wrap justify-content-end gap-2">
                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('¿Confirmas la cancelación de esta cotización?');">Confirmar cancelación</button>
                <a class="btn btn-outline-cavex" href="/Cotizaciones/Details/1">Volver</a>
            </div>
        </form>
    </div>
</div>


