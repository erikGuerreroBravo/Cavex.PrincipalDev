@{
    ViewData["Title"] = "Nueva cotización";
    ViewData["HeaderEyebrow"] = "Operación logística CAVEX";
    ViewData["HeaderTitle"] = "Nueva cotización";
    ViewData["HeaderSubtitle"] = "Captura el servicio durante la llamada, calcula ruta desde sucursal y genera precio final.";
    ViewData["HeaderBadgeText"] = "Cotizador operativo";
}

@section Head {
    <link rel="stylesheet" href="~/css/vista-cotizador.css" asp-append-version="true" />
}

<partial name="_PageHeader" />

<div class="stepper mb-4">
    <span class="step active">1 Solicitante</span>
    <span class="step">2 Pasajero</span>
    <span class="step">3 Servicio</span>
    <span class="step">4 Ruta</span>
    <span class="step">5 Costos</span>
    <span class="step">6 Cotización</span>
</div>

<form action="#" class="quote-form quote-workspace">
    <div class="quote-main-column">
        <partial name="_FormularioSolicitante" />
        <partial name="_FormularioRuta" />
        <partial name="_FormularioCostos" />

        <div class="form-action-bar">
            <a class="btn btn-outline-cavex" asp-controller="Cotizaciones" asp-action="Index">Cancelar</a>
            <button type="submit" class="btn btn-cavex">Calcular cotización</button>
        </div>
    </div>

    <partial name="_SidebarResumen" />
</form>

@section Scripts {
    <script src="~/js/validaciones.js"></script>
    <script src="~/js/cotizaciones-operacion.js"></script>
}



