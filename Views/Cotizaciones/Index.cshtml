@{
    ViewData["Title"] = "Cotizaciones";
    ViewData["HeaderEyebrow"] = "Historial operativo";
    ViewData["HeaderTitle"] = "Cotizaciones";
    ViewData["HeaderSubtitle"] = "Consulta folios, ruta, precio final, estado y acciones de operación.";
    ViewData["HeaderButtonText"] = "Nueva cotización";
    ViewData["HeaderButtonController"] = "Cotizaciones";
    ViewData["HeaderButtonAction"] = "Create";

    ViewData["TableTitle"] = "Resultados de cotizaciones";
    ViewData["TableSubtitle"] = "Mostrando 1-2 de 2 registros, ordenados por creación más reciente.";
    ViewData["TableCount"] = 2;
    ViewData["TableCountLabel"] = "registros";
    ViewData["TableExtraPill"] = "Página 1 de 1";
}

<partial name="_PageHeader" />

<div class="filter-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <span class="eyebrow">Filtros</span>
            <h2 class="filter-title">Búsqueda de cotizaciones</h2>
            <p class="cavex-subtitle">Busca por folio, solicitante, pasajero, teléfono, destino, estado, fechas o precio.</p>
        </div>
        <span class="badge-cavex">3 resultados</span>
    </div>

    <form action="#" class="filter-form-compact">
        <div class="row g-3">
            <div class="col-lg-4">
                <label class="form-label" for="strBusqueda">Buscar texto general</label>
                <input id="strBusqueda" name="busqueda" class="form-control text-uppercase-input" placeholder="FOLIO, NOMBRE, TELÉFONO O DESTINO" />
            </div>
            <div class="col-md-4 col-lg-2">
                <label class="form-label" for="strEstado">Estado</label>
                <select id="strEstado" name="estado" class="form-select">
                    <option value="">Todos</option>
                    <option value="Borrador">Borrador</option>
                    <option value="Cotizada">Cotizada</option>
                    <option value="Enviada">Enviada</option>
                    <option value="Aceptada">Aceptada</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label" for="intServicioId">Servicio</label>
                <select id="intServicioId" name="servicioId" class="form-select">
                    <option value="">Todos</option>
                    <option value="1">Traslado Sencillo</option>
                    <option value="2">Traslado con Asistencia</option>
                </select>
            </div>
            <div class="col-md-4 col-lg-3">
                <label class="form-label" for="intSucursalId">Sucursal</label>
                <select id="intSucursalId" name="sucursalId" class="form-select">
                    <option value="">Todas</option>
                    <option value="1">Base Centro</option>
                    <option value="2">Base Sur</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="strFechaDesde">Fecha desde</label>
                <input id="strFechaDesde" name="fechaDesde" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="strFechaHasta">Fecha hasta</label>
                <input id="strFechaHasta" name="fechaHasta" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="intPrecioMin">Precio mínimo</label>
                <input id="intPrecioMin" name="precioMin" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="intPrecioMax">Precio máximo</label>
                <input id="intPrecioMax" name="precioMax" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="intPageSize">Registros por página</label>
                <select id="intPageSize" name="pageSize" class="form-select">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>

        <div class="search-actions mt-3">
            <button type="submit" class="btn btn-cavex">Buscar</button>
            <a class="btn btn-outline-cavex" asp-controller="Cotizaciones" asp-action="Index">Limpiar filtros</a>
            <a class="btn btn-outline-cavex" asp-controller="Cotizaciones" asp-action="Create">Nueva cotización</a>
        </div>
    </form>
</div>

<div class="cavex-card table-module">
    <partial name="_TableCardHeader"  />
    <div class="table-responsive">
        <table class="table table-hover align-middle executive-table table-cavex-compact" id="strCotizacionesTable">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Cliente</th>
                    <th>Servicio / Sucursal</th>
                    <th>Destino</th>
                    <th>Fecha</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="cotizacion-folio">CAVEX-2024-000001</span></td>
                    <td>
                        <div class="cotizacion-main-text text-clamp-1">Juan Pérez</div>
                        <div class="cotizacion-sub-text text-clamp-1">Pasajero: María López</div>
                        <div class="cotizacion-sub-text">55 1234 5678</div>
                    </td>
                    <td>
                        <div class="cotizacion-main-text text-clamp-1">Traslado Sencillo</div>
                        <div class="cotizacion-sub-text text-clamp-1">Sucursal: Base Centro</div>
                    </td>
                    <td>
                        <div class="text-clamp-2">Av. Reforma 222, CDMX</div>
                    </td>
                    <td>
                        <div class="cotizacion-main-text">15/05/2024</div>
                        <div class="cotizacion-sub-text">14:00</div>
                    </td>
                    <td><strong class="price-highlight">$1,500.00</strong></td>
                    <td><partial name="_StatusBadge" model="@("Cotizada")" /></td>
                    <td class="text-end">
                        <a href="/Cotizaciones/Details/1" class="btn btn-sm btn-outline-cavex">Ver Detalle</a>
                    </td>
                </tr>
                <tr>
                    <td><span class="cotizacion-folio">CAVEX-2024-000002</span></td>
                    <td>
                        <div class="cotizacion-main-text text-clamp-1">Empresa SA de CV</div>
                        <div class="cotizacion-sub-text text-clamp-1">Pasajero: Roberto Gómez</div>
                        <div class="cotizacion-sub-text">55 9876 5432</div>
                    </td>
                    <td>
                        <div class="cotizacion-main-text text-clamp-1">Traslado con Asistencia</div>
                        <div class="cotizacion-sub-text text-clamp-1">Sucursal: Base Sur</div>
                    </td>
                    <td>
                        <div class="text-clamp-2">Hospital ABC, CDMX</div>
                    </td>
                    <td>
                        <div class="cotizacion-main-text">16/05/2024</div>
                        <div class="cotizacion-sub-text">09:30</div>
                    </td>
                    <td><strong class="price-highlight">$2,300.00</strong></td>
                    <td><partial name="_StatusBadge" model="@("Aceptada")" /></td>
                    <td class="text-end">
                        <a href="/Cotizaciones/Details/2" class="btn btn-sm btn-outline-cavex">Ver Detalle</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>



