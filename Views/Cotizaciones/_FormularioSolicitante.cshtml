<div class="cavex-card form-section-card">
    <h3 class="form-section-title"><span class="form-section-number">1</span>Datos del solicitante</h3>
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Nombre</label>
            <input name="NombreSolicitante" id="strNombreSolicitante" class="form-control" placeholder="Nombre del solicitante" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Apellido paterno</label>
            <input name="ApellidoPaternoSolicitante" id="strApellidoPaternoSolicitante" class="form-control" placeholder="Apellido paterno" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Apellido materno</label>
            <input name="ApellidoMaternoSolicitante" id="strApellidoMaternoSolicitante" class="form-control" placeholder="Opcional" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Teléfono celular</label>
            <input name="TelefonoCelular" id="strTelefonoCelular" class="form-control" placeholder="55 1234 5678" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Teléfono fijo</label>
            <input name="TelefonoFijo" id="strTelefonoFijo" class="form-control" placeholder="Opcional" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Correo electrónico</label>
            <input name="Correo" id="strCorreo" type="email" class="form-control" placeholder="correo@empresa.com" />
        </div>
    </div>
</div>

<div class="cavex-card form-section-card">
    <h3 class="form-section-title"><span class="form-section-number">2</span>Dirección del solicitante</h3>
    <div class="row g-3">
        <div class="col-md-12">
            <label class="form-label d-block">żDesea registrar dirección del solicitante?</label>
            <div class="segmented-options">
                <label><input name="RegistrarDireccionSolicitante" id="strRegistrarDireccionSolicitanteSi" type="radio" value="true" /> Sí</label>
                <label><input name="RegistrarDireccionSolicitante" id="strRegistrarDireccionSolicitanteNo" type="radio" value="false" /> No</label>
            </div>
        </div>
    </div>
    <div id="divDireccionSolicitante" class="conditional-block mt-3">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Calle</label>
                <input name="CalleSolicitante" id="strCalleSolicitante" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Número exterior</label>
                <input name="NumeroExteriorSolicitante" id="strNumeroExteriorSolicitante" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Número interior</label>
                <input name="NumeroInteriorSolicitante" id="strNumeroInteriorSolicitante" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Colonia</label>
                <input name="ColoniaSolicitante" id="strColoniaSolicitante" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Municipio / Alcaldía</label>
                <input name="MunicipioSolicitante" id="strMunicipioSolicitante" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Estado</label>
                <input name="EstadoSolicitante" id="strEstadoSolicitante" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Código postal</label>
                <input name="CodigoPostalSolicitante" id="strCodigoPostalSolicitante" class="form-control" />
            </div>
            <div class="col-md-12">
                <label class="form-label">Referencias</label>
                <textarea name="ReferenciasDireccionSolicitante" id="strReferenciasDireccionSolicitante" class="form-control" rows="2"></textarea>
            </div>
        </div>
    </div>
</div>

<div class="cavex-card form-section-card">
    <h3 class="form-section-title"><span class="form-section-number">3</span>Información para brindar mejor atención</h3>
    <p class="text-muted mb-3">Esta información nos ayuda a asignar la unidad y el apoyo adecuado durante el traslado.</p>
    <div class="row g-3">
        <div class="col-md-5">
            <label class="form-label">Nombre del pasajero</label>
            <input name="NombrePasajero" id="strNombrePasajero" class="form-control" required />
        </div>
        <div class="col-md-3">
            <label class="form-label">Cantidad de pasajeros</label>
            <input name="CantidadPasajeros" id="intCantidadPasajeros" type="number" min="1" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">żRequiere atención especial?</label>
            <select name="RequiereAtencionEspecial" id="strRequiereAtencionEspecial" class="form-select">
                <option value="false">No</option>
                <option value="true">Sí</option>
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Tipo de atención</label>
            <select name="TipoAtencionEspecial" id="strTipoAtencionEspecial" class="form-select">
                <option>No requiere apoyo especial</option>
                <option>Requiere apoyo para subir o bajar de la unidad</option>
                <option>Viaja a consulta, hospital o tratamiento médico</option>
                <option>Persona adulta mayor con trato preferente</option>
                <option>Movilidad reducida: bastón, andadera o silla de ruedas</option>
                <option>Viaja acompańado por familiar o cuidador</option>
                <option>Otro</option>
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Observaciones de atención</label>
            <textarea name="ObservacionesAtencion" id="strObservacionesAtencion" class="form-control" rows="2" placeholder="Indicaciones útiles para el equipo operativo"></textarea>
        </div>
    </div>
</div>
